#!/usr/bin/env python3.12
"""
Google Search Console API 클라이언트

사용법:
    gsc sites                              # 등록된 사이트 목록
    gsc query <site_url>                   # 검색 성능 데이터 조회
    gsc query <site_url> --days 30         # 최근 30일 데이터
    gsc query <site_url> --by-date         # 날짜별 조회
    gsc query <site_url> --by-country      # 국가별 조회
    gsc query <site_url> --by-device       # 디바이스별 조회
    gsc sitemaps <site_url>                # 사이트맵 목록
    gsc inspect <site_url> <page_url>      # URL 인덱싱 상태 검사
    gsc validate-index-issues              # 전체 사이트 Page indexing validation 재시작
    gsc validate-index-issues-all          # 저장된 frontend session으로 전체 사이트 validation 재시작
    gsc validate-index-issues-all-browser  # 열린 Chrome 탭으로 전체 사이트 validation 재시작

설정:
    1. Google Cloud Console에서 OAuth 2.0 클라이언트 ID 생성
    2. 클라이언트 시크릿 JSON 파일 다운로드
    3. 환경변수 설정: export GOOGLE_CLIENT_SECRET=~/.config/google/client_secret.json
    4. 첫 실행 시 브라우저에서 OAuth 인증 수행 (토큰 자동 저장)
"""

import argparse
import json
import os
import pickle
import subprocess
import sys
from datetime import datetime, timedelta
from pathlib import Path

try:
    from google.auth.transport.requests import Request
    from google.oauth2.credentials import Credentials
    from google_auth_oauthlib.flow import InstalledAppFlow
    from googleapiclient.discovery import build
    import requests
except ImportError:
    print("필수 패키지가 설치되어 있지 않습니다. 다음 명령어로 설치하세요:")
    print("  pip install google-auth google-auth-oauthlib google-api-python-client requests")
    sys.exit(1)

WEBMASTERS_READONLY_SCOPE = 'https://www.googleapis.com/auth/webmasters.readonly'
WEBMASTERS_WRITE_SCOPE = 'https://www.googleapis.com/auth/webmasters'

# API 스코프 (URL Inspection API 포함)
SCOPES = [
    WEBMASTERS_READONLY_SCOPE,
    WEBMASTERS_WRITE_SCOPE,
]

# 인증 파일 경로
CLIENT_SECRET_FILE = os.environ.get(
    'GOOGLE_CLIENT_SECRET',
    os.path.expanduser('~/.config/google/client_secret.json')
)
TOKEN_FILE = os.path.expanduser('~/.config/gsc/token.pickle')


def get_credentials():
    """OAuth 2.0 인증을 수행하고 credentials를 반환합니다."""
    creds = None
    token_path = Path(TOKEN_FILE)

    # 저장된 토큰이 있으면 먼저 로드 시도
    if token_path.exists():
        with open(token_path, 'rb') as token:
            creds = pickle.load(token)

    # 토큰이 유효하면 바로 반환
    if creds and creds.valid:
        return creds

    # 토큰이 만료되었지만 refresh 가능하면 갱신
    if creds and creds.expired and creds.refresh_token:
        try:
            creds.refresh(Request())
            with open(token_path, 'wb') as token:
                pickle.dump(creds, token)
            return creds
        except Exception as e:
            print(f"토큰 갱신 실패: {e}")

    # 새로 인증이 필요한 경우 - client_secret 필요
    if not os.path.exists(CLIENT_SECRET_FILE):
        print(f"오류: 클라이언트 시크릿 파일을 찾을 수 없습니다: {CLIENT_SECRET_FILE}")
        print()
        print("설정 방법:")
        print("  1. Google Cloud Console에서 OAuth 2.0 클라이언트 ID 생성")
        print("  2. 클라이언트 시크릿 JSON 파일 다운로드")
        print("  3. 파일을 ~/.config/google/client_secret.json에 저장")
        print("     또는 GOOGLE_CLIENT_SECRET 환경변수로 경로 지정")
        sys.exit(1)

    flow = InstalledAppFlow.from_client_secrets_file(CLIENT_SECRET_FILE, SCOPES)
    creds = flow.run_local_server(port=0)

    # 토큰 저장
    token_path.parent.mkdir(parents=True, exist_ok=True)
    with open(token_path, 'wb') as token:
        pickle.dump(creds, token)

    return creds


def credential_scopes(creds) -> set[str]:
    """토큰에 실제 부여된 OAuth scope 목록을 반환합니다."""
    scopes = set(getattr(creds, 'granted_scopes', None) or [])
    scopes.update(getattr(creds, 'scopes', None) or [])
    return scopes


def credential_has_write_scope(creds) -> bool:
    """사이트맵 제출에 필요한 Search Console 쓰기 scope가 있는지 확인합니다."""
    return WEBMASTERS_WRITE_SCOPE in credential_scopes(creds)


def print_write_scope_error() -> None:
    print("오류: 현재 GSC OAuth 토큰에 사이트맵 제출 쓰기 권한이 없습니다.")
    print(f"필요 scope: {WEBMASTERS_WRITE_SCOPE}")
    print("현재 토큰을 백업/삭제한 뒤 재인증해야 합니다:")
    print(f"  mv {TOKEN_FILE} {TOKEN_FILE}.readonly-backup")
    print("  gsc sites")


def get_service():
    """Search Console API 서비스 객체를 반환합니다."""
    creds = get_credentials()
    return build('searchconsole', 'v1', credentials=creds)


def get_site_entries():
    """등록된 사이트 목록을 반환합니다."""
    service = get_service()
    response = service.sites().list().execute()
    return response.get('siteEntry', [])


def list_sites():
    """등록된 사이트 목록을 출력합니다."""
    sites = get_site_entries()
    if not sites:
        print("등록된 사이트가 없습니다.")
        return

    print(f"\n{'=' * 60}")
    print("  등록된 사이트 목록")
    print(f"{'=' * 60}\n")

    for site in sites:
        url = site.get('siteUrl', '')
        permission = site.get('permissionLevel', '')
        print(f"  {url}")
        print(f"    권한: {permission}\n")


def get_sitemaps(service, site_url: str) -> list[dict]:
    """사이트맵 목록을 반환합니다."""
    response = service.sitemaps().list(siteUrl=site_url).execute()
    return response.get('sitemap', [])


def list_sitemaps(site_url: str):
    """사이트맵 목록을 조회합니다."""
    service = get_service()

    try:
        sitemaps = get_sitemaps(service, site_url)
    except Exception as e:
        print(f"오류: {e}")
        return

    print(f"\n{'=' * 80}")
    print(f"  사이트맵 목록: {site_url}")
    print(f"{'=' * 80}\n")

    if not sitemaps:
        print("  등록된 사이트맵이 없습니다.")
        return

    print(f"{'상태':<12} {'유형':<12} {'제출일':<12} {'URL 수':>10}  경로")
    print("-" * 80)

    for sitemap in sitemaps:
        path = sitemap.get('path', '')
        sitemap_type = sitemap.get('type', 'N/A')
        last_submitted = sitemap.get('lastSubmitted', '')[:10] if sitemap.get('lastSubmitted') else 'N/A'

        # 콘텐츠 정보
        contents = sitemap.get('contents', [])
        total_urls = sum(int(c.get('submitted', 0) or 0) for c in contents)
        indexed_urls = sum(int(c.get('indexed', 0) or 0) for c in contents)

        # 오류/경고 상태
        errors = int(sitemap.get('errors', 0) or 0)
        warnings_count = int(sitemap.get('warnings', 0) or 0)

        if errors > 0:
            status = f"오류 {errors}"
        elif warnings_count > 0:
            status = f"경고 {warnings_count}"
        else:
            status = "정상"

        print(f"{status:<12} {sitemap_type:<12} {last_submitted:<12} {total_urls:>10}  {path}")

        # 상세 콘텐츠 정보
        for content in contents:
            content_type = content.get('type', '')
            submitted = int(content.get('submitted', 0) or 0)
            indexed = int(content.get('indexed', 0) or 0)
            if submitted > 0:
                print(f"{'':>12} └─ {content_type}: 제출 {submitted}, 인덱싱 {indexed}")

    print(f"\n총 {len(sitemaps)}개 사이트맵")


def submit_sitemap(site_url: str, sitemap_url: str, service=None) -> bool:
    """Search Console API로 사이트맵을 제출/재제출합니다."""
    if service is None:
        creds = get_credentials()
        if not credential_has_write_scope(creds):
            print_write_scope_error()
            return False
        service = build('searchconsole', 'v1', credentials=creds)
    try:
        service.sitemaps().submit(siteUrl=site_url, feedpath=sitemap_url).execute()
    except Exception as e:
        print(f"FAIL {site_url} {sitemap_url}: {e}")
        return False
    print(f"OK   {site_url} {sitemap_url}")
    return True


def refresh_sitemaps(site_urls: list[str] | None = None,
                     include_domain_properties: bool = False) -> None:
    """등록된 사이트맵을 모두 재제출합니다.

    참고: Google은 일반 웹페이지의 Search Console 'Request indexing' 기능을
    공개 API로 제공하지 않습니다. 이 명령은 API로 가능한 대체 작업인
    등록 사이트맵 재제출을 수행합니다.
    """
    creds = get_credentials()
    if not credential_has_write_scope(creds):
        print_write_scope_error()
        return
    service = build('searchconsole', 'v1', credentials=creds)
    if site_urls:
        sites = [{'siteUrl': url, 'permissionLevel': ''} for url in site_urls]
    else:
        sites = get_site_entries()

    total_sites = 0
    total_sitemaps = 0
    ok_count = 0
    fail_count = 0
    skipped_count = 0

    print("Search Console 일반 URL 'Request indexing'은 공개 API가 없어 실행하지 않습니다.")
    print("대신 API로 가능한 등록 사이트맵 재제출을 수행합니다.\n")

    for site in sites:
        site_url = site.get('siteUrl', '')
        if not site_url:
            continue
        if site_url.startswith('sc-domain:') and not include_domain_properties:
            print(f"SKIP {site_url}: 도메인 속성은 기본 재제출 대상에서 제외 (--include-domain-properties로 포함)")
            skipped_count += 1
            continue

        total_sites += 1
        try:
            sitemaps = get_sitemaps(service, site_url)
        except Exception as e:
            print(f"FAIL {site_url}: 사이트맵 조회 실패: {e}")
            fail_count += 1
            continue

        if not sitemaps:
            print(f"SKIP {site_url}: 등록된 사이트맵 없음")
            skipped_count += 1
            continue

        print(f"[{site_url}] {len(sitemaps)}개 사이트맵 재제출")
        for sitemap in sitemaps:
            path = sitemap.get('path', '')
            if not path:
                skipped_count += 1
                continue
            total_sitemaps += 1
            if submit_sitemap(site_url, path, service):
                ok_count += 1
            else:
                fail_count += 1

    print("\n요약")
    print(f"  대상 사이트: {total_sites}")
    print(f"  재제출 사이트맵: {ok_count}/{total_sitemaps}")
    print(f"  실패: {fail_count}")
    print(f"  스킵: {skipped_count}")


def explain_request_indexing_api() -> None:
    """일반 URL 색인 요청 자동화 가능 여부를 설명합니다."""
    print("Google Search Console의 일반 URL 'Request indexing' 동작은 공개 API/CLI로 제공되지 않습니다.")
    print("URL Inspection API는 상태 조회만 지원하고, Search Console API는 사이트맵 제출/조회와 성능 조회를 지원합니다.")
    print("Indexing API의 URL_UPDATED 알림은 Google 문서상 JobPosting/BroadcastEvent 등 제한된 콘텐츠에만 권장/지원됩니다.")
    print("따라서 일반 문서/마케팅 페이지 전체 갱신은 사이트맵 재제출(refresh-sitemaps)로 처리하는 것이 안전한 자동화 경로입니다.")


def request_indexing_via_browser(args) -> int:
    """열린 Chrome/GSC 브라우저 세션을 사용해 프론트엔드 색인 요청 helper를 실행합니다."""
    helper = Path(__file__).with_name('gsc-browser-indexing')
    cmd = [str(helper), '--site', args.site_url]
    if args.url:
        cmd.extend(['--url', args.url])
    if args.file:
        cmd.extend(['--file', args.file])
    if args.submit:
        cmd.append('--submit')
    if args.limit is not None:
        cmd.extend(['--limit', str(args.limit)])
    if args.delay_ms is not None:
        cmd.extend(['--delay-ms', str(args.delay_ms)])
    if args.port is not None:
        cmd.extend(['--port', str(args.port)])
    if args.probe:
        cmd = [str(helper), '--probe']
        if args.port is not None:
            cmd.extend(['--port', str(args.port)])
    return subprocess.call(cmd)


def validate_index_issues_via_browser(args) -> int:
    """열린 Chrome/GSC 브라우저 세션으로 Page indexing 이슈별 Start New Validation을 실행합니다."""
    helper = Path(__file__).with_name('gsc-browser-indexing')
    cmd = [str(helper), '--site', args.site_url, '--index-issues']
    if args.submit:
        cmd.append('--submit')
    if args.only_status is not None:
        cmd.extend(['--only-status', args.only_status])
    if args.include_started:
        cmd.append('--include-started')
    if args.limit is not None:
        cmd.extend(['--limit', str(args.limit)])
    if args.delay_ms is not None:
        cmd.extend(['--delay-ms', str(args.delay_ms)])
    if args.port is not None:
        cmd.extend(['--port', str(args.port)])
    return subprocess.call(cmd)



def build_validate_index_issues_frontend_cmd(args, site_url: str) -> list[str]:
    """저장된 GSC frontend session으로 실행하는 direct helper 명령을 구성합니다."""
    helper = Path(__file__).with_name('gsc-frontend-indexing')
    cmd = [str(helper), '--site', site_url, '--index-issues']
    if getattr(args, 'submit', False):
        cmd.append('--submit')
    if getattr(args, 'session_file', None):
        cmd.extend(['--session-file', args.session_file])
    if getattr(args, 'only_status', None) is not None:
        cmd.extend(['--only-status', args.only_status])
    if getattr(args, 'include_started', False):
        cmd.append('--include-started')
    issue_limit = getattr(args, 'issue_limit', None)
    if issue_limit is None:
        issue_limit = getattr(args, 'limit', None)
    if issue_limit is not None:
        cmd.extend(['--limit', str(issue_limit)])
    if getattr(args, 'delay_ms', None) is not None:
        cmd.extend(['--delay-ms', str(args.delay_ms)])
    return cmd


def build_validate_index_issues_browser_cmd(args, site_url: str) -> list[str]:
    """단일 사이트 Page indexing validation helper 명령을 구성합니다."""
    helper = Path(__file__).with_name('gsc-browser-indexing')
    cmd = [str(helper), '--site', site_url, '--index-issues']
    if getattr(args, 'submit', False):
        cmd.append('--submit')
    if getattr(args, 'only_status', None) is not None:
        cmd.extend(['--only-status', args.only_status])
    if getattr(args, 'include_started', False):
        cmd.append('--include-started')
    issue_limit = getattr(args, 'issue_limit', None)
    if issue_limit is None:
        issue_limit = getattr(args, 'limit', None)
    if issue_limit is not None:
        cmd.extend(['--limit', str(issue_limit)])
    if getattr(args, 'delay_ms', None) is not None:
        cmd.extend(['--delay-ms', str(args.delay_ms)])
    if getattr(args, 'port', None) is not None:
        cmd.extend(['--port', str(args.port)])
    if getattr(args, 'connect_timeout_ms', None) is not None:
        cmd.extend(['--connect-timeout-ms', str(args.connect_timeout_ms)])
    return cmd


def build_validate_index_issues_browser_batch_cmd(args, site_urls: list[str]) -> list[str]:
    """Build one browser helper invocation that keeps a single Chrome attach for all sites."""
    if not site_urls:
        raise ValueError('site_urls must not be empty')
    cmd = build_validate_index_issues_browser_cmd(args, site_urls[0])
    for site_url in site_urls[1:]:
        cmd.extend(['--site', site_url])
    if getattr(args, 'site_delay_ms', None) is not None:
        cmd.extend(['--site-delay-ms', str(args.site_delay_ms)])
    return cmd


def run_validate_index_issues_site(cmd: list[str], timeout_ms: int | None = None) -> int:
    """Run one per-site validation helper and return a process-style status code."""
    try:
        completed = subprocess.run(
            cmd,
            timeout=(timeout_ms / 1000) if timeout_ms else None,
        )
        return completed.returncode
    except subprocess.TimeoutExpired:
        print(f"ERROR: site validation helper timed out after {timeout_ms}ms")
        return 124


def select_validation_sites(site_entries: list[dict], include_domain_properties: bool = False,
                            only_sites: list[str] | None = None,
                            limit_sites: int | None = None) -> tuple[list[str], list[tuple[str, str]]]:
    """GSC siteEntry 목록에서 validation 대상 property URL을 고릅니다."""
    only = set(only_sites or [])
    selected: list[str] = []
    skipped: list[tuple[str, str]] = []

    for entry in site_entries:
        site_url = entry.get('siteUrl', '')
        if not site_url:
            continue
        if only and site_url not in only:
            continue
        if site_url.startswith('sc-domain:') and not include_domain_properties:
            skipped.append((site_url, 'domain property skipped by default'))
            continue
        selected.append(site_url)
        if limit_sites is not None and len(selected) >= limit_sites:
            break

    return selected, skipped


def validate_all_index_issues(args, browser: bool = False) -> int:
    """관리 중인 GSC 사이트를 조회하고 각 사이트별 Page indexing validation을 실행합니다."""
    if getattr(args, 'browser', False):
        browser = True
    sites = get_site_entries()
    selected, skipped = select_validation_sites(
        sites,
        include_domain_properties=args.include_domain_properties,
        only_sites=args.site or None,
        limit_sites=args.limit_sites,
    )

    mode = 'browser-cdp' if browser else 'frontend-session'
    print("GSC Page indexing issue validation 전체 사이트 처리")
    print(f"  mode: {mode}")
    print(f"  submit: {args.submit}")
    print(f"  only_status: {args.only_status}")
    print(f"  include_started: {args.include_started}")
    print(f"  discovered_sites: {len(sites)}")
    print(f"  selected_sites: {len(selected)}")
    if skipped:
        print(f"  skipped_sites: {len(skipped)}")
        for site_url, reason in skipped:
            print(f"    SKIP {site_url}: {reason}")
    print()
    sys.stdout.flush()

    if not selected:
        print("처리 대상 사이트가 없습니다.")
        return 0

    results: list[dict] = []
    if browser:
        print(f"\n{'=' * 80}")
        print(f"[browser-batch] {len(selected)} sites")
        print(f"{'=' * 80}")
        sys.stdout.flush()
        cmd = build_validate_index_issues_browser_batch_cmd(args, selected)
        returncode = run_validate_index_issues_site(cmd, getattr(args, 'batch_timeout_ms', None))
        print(f"\n{'=' * 80}")
        print("요약")
        print(f"  대상 사이트: {len(selected)}")
        print(f"  browser-batch: {'OK' if returncode == 0 else f'FAIL({returncode})'}")
        print("  세부 사이트별 성공/실패는 위 browser helper summary를 확인하세요.")
        return returncode

    for idx, site_url in enumerate(selected, 1):
        print(f"\n{'=' * 80}")
        print(f"[{idx}/{len(selected)}] {site_url}")
        print(f"{'=' * 80}")
        sys.stdout.flush()
        cmd = build_validate_index_issues_browser_cmd(args, site_url) if browser else build_validate_index_issues_frontend_cmd(args, site_url)
        returncode = run_validate_index_issues_site(cmd, getattr(args, 'site_timeout_ms', None))
        if returncode != 0 and not browser and getattr(args, 'submit', False):
            print(f"Frontend direct validation failed; retrying with browser fallback: {site_url}")
            sys.stdout.flush()
            fallback_cmd = build_validate_index_issues_browser_cmd(args, site_url)
            fallback_timeout = getattr(args, 'batch_timeout_ms', None) or getattr(args, 'site_timeout_ms', None)
            returncode = run_validate_index_issues_site(fallback_cmd, fallback_timeout)
        if returncode != 0 and browser and getattr(args, 'retry_failed_sites', 0):
            for retry_idx in range(args.retry_failed_sites):
                print(f"Retrying failed site ({retry_idx + 1}/{args.retry_failed_sites}): {site_url}")
                sys.stdout.flush()
                returncode = run_validate_index_issues_site(cmd, getattr(args, 'site_timeout_ms', None))
                if returncode == 0:
                    break
        results.append({'siteUrl': site_url, 'returncode': returncode})
        if idx < len(selected) and args.site_delay_ms:
            import time
            time.sleep(args.site_delay_ms / 1000)

    ok_count = sum(1 for result in results if result['returncode'] == 0)
    fail_count = len(results) - ok_count
    print(f"\n{'=' * 80}")
    print("요약")
    print(f"  대상 사이트: {len(results)}")
    print(f"  성공: {ok_count}")
    print(f"  실패: {fail_count}")
    for result in results:
        status = 'OK' if result['returncode'] == 0 else f"FAIL({result['returncode']})"
        print(f"  {status} {result['siteUrl']}")

    return 0 if fail_count == 0 else 1


def inspect_url(site_url: str, page_url: str):
    """URL 인덱싱 상태를 검사합니다."""
    creds = get_credentials()

    # URL Inspection API는 별도 엔드포인트 사용
    endpoint = 'https://searchconsole.googleapis.com/v1/urlInspection/index:inspect'

    headers = {
        'Authorization': f'Bearer {creds.token}',
        'Content-Type': 'application/json',
    }

    body = {
        'inspectionUrl': page_url,
        'siteUrl': site_url,
    }

    try:
        response = requests.post(endpoint, headers=headers, json=body)
        response.raise_for_status()
        result = response.json()
    except requests.exceptions.HTTPError as e:
        if response.status_code == 403:
            print("오류: URL Inspection API 접근 권한이 없습니다.")
            print("토큰을 삭제하고 재인증하세요: rm ~/.config/gsc/token.pickle")
        else:
            print(f"API 오류: {e}")
            print(f"응답: {response.text}")
        return
    except Exception as e:
        print(f"오류: {e}")
        return

    inspection = result.get('inspectionResult', {})
    index_status = inspection.get('indexStatusResult', {})
    crawl_status = inspection.get('crawlStatusResult', {}) if 'crawlStatusResult' in inspection else {}
    mobile_status = inspection.get('mobileUsabilityResult', {})
    rich_results = inspection.get('richResultsResult', {})

    print(f"\n{'=' * 70}")
    print(f"  URL 검사 결과")
    print(f"{'=' * 70}")
    print(f"  검사 URL: {page_url}")
    print(f"  사이트: {site_url}")
    print(f"{'=' * 70}\n")

    # 인덱싱 상태
    print("[ 인덱싱 상태 ]")
    verdict = index_status.get('verdict', 'N/A')
    verdict_display = {
        'PASS': '✅ 인덱싱됨',
        'PARTIAL': '⚠️ 부분 인덱싱',
        'FAIL': '❌ 인덱싱 안됨',
        'NEUTRAL': '➖ 중립',
    }.get(verdict, verdict)
    print(f"  상태: {verdict_display}")

    coverage_state = index_status.get('coverageState', '')
    if coverage_state:
        print(f"  커버리지: {coverage_state}")

    robotstxt_state = index_status.get('robotsTxtState', '')
    if robotstxt_state:
        print(f"  robots.txt: {robotstxt_state}")

    indexing_state = index_status.get('indexingState', '')
    if indexing_state:
        print(f"  인덱싱 허용: {indexing_state}")

    last_crawl = index_status.get('lastCrawlTime', '')
    if last_crawl:
        print(f"  마지막 크롤링: {last_crawl[:19].replace('T', ' ')}")

    page_fetch_state = index_status.get('pageFetchState', '')
    if page_fetch_state:
        print(f"  페이지 가져오기: {page_fetch_state}")

    google_canonical = index_status.get('googleCanonical', '')
    if google_canonical:
        print(f"  Google 선택 Canonical: {google_canonical}")

    user_canonical = index_status.get('userCanonical', '')
    if user_canonical:
        print(f"  사용자 지정 Canonical: {user_canonical}")

    crawled_as = index_status.get('crawledAs', '')
    if crawled_as:
        print(f"  크롤링 에이전트: {crawled_as}")

    # 참조 URL
    referring_urls = index_status.get('referringUrls', [])
    if referring_urls:
        print(f"\n  참조 URL:")
        for url in referring_urls[:5]:
            print(f"    - {url}")

    # 사이트맵 정보
    sitemap_info = index_status.get('sitemap', [])
    if sitemap_info:
        print(f"\n  사이트맵에서 발견:")
        for sm in sitemap_info[:3]:
            print(f"    - {sm}")

    # 모바일 사용성
    if mobile_status:
        print(f"\n[ 모바일 사용성 ]")
        mobile_verdict = mobile_status.get('verdict', 'N/A')
        mobile_display = {
            'PASS': '✅ 모바일 친화적',
            'FAIL': '❌ 모바일 문제 있음',
            'NEUTRAL': '➖ 확인 불가',
        }.get(mobile_verdict, mobile_verdict)
        print(f"  상태: {mobile_display}")

        issues = mobile_status.get('issues', [])
        if issues:
            print(f"  문제점:")
            for issue in issues:
                print(f"    - {issue.get('issueType', '')} ({issue.get('severity', '')})")

    # 리치 결과
    if rich_results and rich_results.get('detectedItems'):
        print(f"\n[ 리치 결과 ]")
        detected = rich_results.get('detectedItems', [])
        for item in detected:
            rich_type = item.get('richResultType', '')
            print(f"  - {rich_type}")
            for issue in item.get('items', []):
                for i in issue.get('issues', []):
                    print(f"    └─ {i.get('issueMessage', '')} ({i.get('severity', '')})")


def query_search_analytics(site_url: str, days: int = 7, dimensions: list = None,
                           row_limit: int = 100, start_row: int = 0):
    """검색 성능 데이터를 조회합니다."""
    service = get_service()

    end_date = datetime.now() - timedelta(days=3)  # 최근 3일은 데이터 불완전
    start_date = end_date - timedelta(days=days)

    if dimensions is None:
        dimensions = ['query', 'page']

    request_body = {
        'startDate': start_date.strftime('%Y-%m-%d'),
        'endDate': end_date.strftime('%Y-%m-%d'),
        'dimensions': dimensions,
        'rowLimit': row_limit,
        'startRow': start_row,
    }

    response = service.searchanalytics().query(
        siteUrl=site_url,
        body=request_body
    ).execute()

    rows = response.get('rows', [])

    print(f"\n{'=' * 80}")
    print(f"  검색 성능 데이터: {site_url}")
    print(f"  기간: {start_date.strftime('%Y-%m-%d')} ~ {end_date.strftime('%Y-%m-%d')}")
    print(f"  차원: {', '.join(dimensions)}")
    print(f"{'=' * 80}\n")

    if not rows:
        print("  데이터가 없습니다.")
        return

    # 차원에 따른 출력 형식
    if dimensions == ['query', 'page']:
        print(f"{'클릭':>8} {'노출':>10} {'CTR':>8} {'순위':>8}  검색어 / 페이지")
        print("-" * 80)
        for row in rows[:50]:
            keys = row.get('keys', [])
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            position = row.get('position', 0)
            query = keys[0] if len(keys) > 0 else ''
            page = keys[1] if len(keys) > 1 else ''
            print(f"{clicks:>8} {impressions:>10} {ctr:>7.1f}% {position:>8.1f}  {query[:30]}")
            if page:
                print(f"{' ' * 40}  {page[:60]}")

    elif dimensions == ['date']:
        print(f"{'날짜':<12} {'클릭':>8} {'노출':>10} {'CTR':>8} {'평균순위':>8}")
        print("-" * 60)
        for row in rows:
            date = row.get('keys', [''])[0]
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            position = row.get('position', 0)
            print(f"{date:<12} {clicks:>8} {impressions:>10} {ctr:>7.1f}% {position:>8.1f}")

    elif dimensions == ['country']:
        print(f"{'국가':<8} {'클릭':>10} {'노출':>12} {'CTR':>8} {'평균순위':>8}")
        print("-" * 60)
        for row in rows:
            country = row.get('keys', [''])[0]
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            position = row.get('position', 0)
            print(f"{country:<8} {clicks:>10} {impressions:>12} {ctr:>7.1f}% {position:>8.1f}")

    elif dimensions == ['device']:
        print(f"{'디바이스':<12} {'클릭':>10} {'노출':>12} {'CTR':>8} {'평균순위':>8}")
        print("-" * 60)
        device_names = {'DESKTOP': '데스크톱', 'MOBILE': '모바일', 'TABLET': '태블릿'}
        for row in rows:
            device = row.get('keys', [''])[0]
            device_display = device_names.get(device, device)
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            position = row.get('position', 0)
            print(f"{device_display:<12} {clicks:>10} {impressions:>12} {ctr:>7.1f}% {position:>8.1f}")

    elif dimensions == ['searchAppearance']:
        print(f"{'검색 형태':<30} {'클릭':>10} {'노출':>12} {'CTR':>8}")
        print("-" * 70)
        for row in rows:
            appearance = row.get('keys', [''])[0]
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            print(f"{appearance:<30} {clicks:>10} {impressions:>12} {ctr:>7.1f}%")

    else:
        # 기타 차원 조합
        print(f"{'키':>40} {'클릭':>8} {'노출':>10} {'CTR':>8} {'순위':>8}")
        print("-" * 80)
        for row in rows[:50]:
            keys = ' | '.join(row.get('keys', []))
            clicks = row.get('clicks', 0)
            impressions = row.get('impressions', 0)
            ctr = row.get('ctr', 0) * 100
            position = row.get('position', 0)
            print(f"{keys[:40]:>40} {clicks:>8} {impressions:>10} {ctr:>7.1f}% {position:>8.1f}")

    print(f"\n총 {len(rows)}개 행 (조회 범위: {start_row+1}~{start_row+row_limit})")


def query_pages(site_url: str, days: int = 7, row_limit: int = 50):
    """페이지별 검색 성능을 조회합니다."""
    service = get_service()

    end_date = datetime.now() - timedelta(days=3)
    start_date = end_date - timedelta(days=days)

    request_body = {
        'startDate': start_date.strftime('%Y-%m-%d'),
        'endDate': end_date.strftime('%Y-%m-%d'),
        'dimensions': ['page'],
        'rowLimit': row_limit,
    }

    response = service.searchanalytics().query(
        siteUrl=site_url,
        body=request_body
    ).execute()

    rows = response.get('rows', [])

    print(f"\n{'=' * 90}")
    print(f"  페이지별 검색 성능: {site_url}")
    print(f"  기간: {start_date.strftime('%Y-%m-%d')} ~ {end_date.strftime('%Y-%m-%d')}")
    print(f"{'=' * 90}\n")

    if not rows:
        print("  데이터가 없습니다.")
        return

    print(f"{'클릭':>8} {'노출':>10} {'CTR':>8} {'순위':>8}  페이지 URL")
    print("-" * 90)

    for row in rows:
        page = row.get('keys', [''])[0]
        clicks = row.get('clicks', 0)
        impressions = row.get('impressions', 0)
        ctr = row.get('ctr', 0) * 100
        position = row.get('position', 0)
        print(f"{clicks:>8} {impressions:>10} {ctr:>7.1f}% {position:>8.1f}  {page[:70]}")

    print(f"\n총 {len(rows)}개 페이지")


def main():
    parser = argparse.ArgumentParser(
        description='Google Search Console CLI',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
예시:
  gsc sites                                    # 사이트 목록
  gsc query https://example.com/ --days 30    # 검색 성능 (30일)
  gsc query https://example.com/ --by-country # 국가별 분석
  gsc sitemaps https://example.com/           # 사이트맵 목록
  gsc submit-sitemap https://example.com/ https://example.com/sitemap.xml
  gsc refresh-sitemaps                        # 관리 중인 URL-prefix 속성의 등록 사이트맵 재제출
  gsc request-indexing-info                   # 일반 URL 색인 요청 API 지원 여부 설명
  gsc request-indexing-browser --probe        # 열린 Chrome/GSC 세션 확인
  gsc request-indexing-browser https://example.com/ --url https://example.com/page --submit
  gsc frontend-session export                 # 열린 Chrome GSC 탭에서 frontend session 저장
  gsc validate-index-issues-all --submit      # 저장된 session으로 직접 frontend 호출
  gsc validate-index-issues-browser https://example.com/ --submit
  gsc validate-index-issues-all-browser --submit
  gsc inspect https://example.com/ /page      # URL 인덱싱 검사
  gsc pages https://example.com/              # 페이지별 성능
"""
    )
    subparsers = parser.add_subparsers(dest='command', help='명령어')

    # sites 명령어
    subparsers.add_parser('sites', help='등록된 사이트 목록')

    # sitemaps 명령어
    sitemaps_parser = subparsers.add_parser('sitemaps', help='사이트맵 목록 조회')
    sitemaps_parser.add_argument('site_url', help='사이트 URL')

    # submit-sitemap 명령어
    submit_sitemap_parser = subparsers.add_parser('submit-sitemap', help='사이트맵 제출/재제출')
    submit_sitemap_parser.add_argument('site_url', help='사이트 URL')
    submit_sitemap_parser.add_argument('sitemap_url', help='사이트맵 URL')

    # refresh-sitemaps 명령어
    refresh_parser = subparsers.add_parser('refresh-sitemaps', help='등록된 사이트맵 일괄 재제출')
    refresh_parser.add_argument('site_urls', nargs='*', help='대상 사이트 URL. 생략하면 관리 중인 전체 사이트')
    refresh_parser.add_argument(
        '--include-domain-properties',
        action='store_true',
        help='sc-domain 속성까지 포함 (기본: URL-prefix 속성만)',
    )

    # request-indexing-info 명령어
    subparsers.add_parser('request-indexing-info', help='일반 URL 색인 요청 API 지원 여부 설명')

    # frontend-session 명령어
    frontend_session_parser = subparsers.add_parser(
        'frontend-session',
        help='GSC frontend 직접 호출용 세션 관리',
    )
    frontend_session_subparsers = frontend_session_parser.add_subparsers(dest='frontend_session_command')
    frontend_export_parser = frontend_session_subparsers.add_parser('export', help='열린 Chrome GSC 탭에서 쿠키/WIZ 토큰 저장')
    frontend_export_parser.add_argument('--session-file', help='저장할 frontend session 파일 경로')
    frontend_export_parser.add_argument('--port', type=int, help='Chrome remote debugging 포트')

    # request-indexing-browser 명령어
    browser_index_parser = subparsers.add_parser(
        'request-indexing-browser',
        help='열린 Chrome/GSC 브라우저 세션으로 프론트엔드 색인 요청 실행',
    )
    browser_index_parser.add_argument('site_url', nargs='?', help='사이트 URL')
    browser_index_parser.add_argument('--url', help='단일 요청 URL')
    browser_index_parser.add_argument('--file', help='요청 URL 목록 파일')
    browser_index_parser.add_argument('--submit', action='store_true', help='실제 Request indexing 제출')
    browser_index_parser.add_argument('--probe', action='store_true', help='브라우저 세션 연결만 확인')
    browser_index_parser.add_argument('--limit', type=int, help='파일 입력에서 처리할 최대 URL 수')
    browser_index_parser.add_argument('--delay-ms', type=int, help='URL 사이 지연 시간(ms)')
    browser_index_parser.add_argument('--port', type=int, help='Chrome remote debugging 포트')

    # validate-index-issues-browser 명령어
    validation_parser = subparsers.add_parser(
        'validate-index-issues-browser',
        help='열린 Chrome/GSC 세션으로 Page indexing 이슈별 Start New Validation 실행',
    )
    validation_parser.add_argument('site_url', help='사이트 URL')
    validation_parser.add_argument('--submit', action='store_true', help='실제 START NEW VALIDATION 클릭')
    validation_parser.add_argument('--only-status', default='actionable', help='처리할 Validation 상태 (기본: actionable = Failed + Not Started, all도 actionable과 동일)')
    validation_parser.add_argument('--include-started', action='store_true', help='Started 상태 이슈도 후보에 포함')
    validation_parser.add_argument('--limit', type=int, help='처리할 최대 이슈 수')
    validation_parser.add_argument('--delay-ms', type=int, help='이슈 사이 지연 시간(ms)')
    validation_parser.add_argument('--port', type=int, help='Chrome remote debugging 포트')

    def add_validate_all_arguments(p):
        p.add_argument('--submit', action='store_true', help='실제 START NEW VALIDATION 요청')
        p.add_argument('--site', action='append', help='특정 사이트 URL만 처리 (여러 번 지정 가능)')
        p.add_argument('--session-file', help='GSC frontend session 파일 경로')
        p.add_argument(
            '--include-domain-properties',
            action='store_true',
            help='sc-domain 속성까지 포함 (기본: URL-prefix 속성만)',
        )
        p.add_argument('--only-status', default='actionable', help='처리할 Validation 상태 (기본: actionable = Failed + Not Started, all도 actionable과 동일)')
        p.add_argument('--include-started', action='store_true', help='Started 상태 이슈도 후보에 포함')
        p.add_argument('--limit-sites', type=int, help='처리할 최대 사이트 수')
        p.add_argument('--issue-limit', type=int, help='사이트별 처리할 최대 이슈 수')
        p.add_argument('--delay-ms', type=int, help='사이트 내부 이슈 사이 지연 시간(ms)')
        p.add_argument('--site-delay-ms', type=int, default=3000, help='사이트 사이 지연 시간(ms, 기본: 3000)')
        p.add_argument('--browser', action='store_true', help='저장 session 대신 열린 Chrome/GSC 세션으로 처리')
        p.add_argument('--port', type=int, help='Chrome remote debugging 포트 (--browser에서 사용)')
        p.add_argument('--retry-failed-sites', type=int, default=0, help='사이트 helper 실패 시 재시도 횟수 (--browser에서 유용)')
        p.add_argument('--site-timeout-ms', type=int, default=180000, help='사이트별 helper 최대 실행 시간(ms, 기본: 180000)')
        p.add_argument('--batch-timeout-ms', type=int, default=900000, help='browser batch helper 최대 실행 시간(ms, 기본: 900000)')
        p.add_argument('--connect-timeout-ms', type=int, default=120000, help='Chrome DevTools 연결/승인 대기 시간(ms, 기본: 120000)')

    # validate-index-issues 명령어: 사용자가 기대하는 전체 사이트 기본 entrypoint
    validation_alias_parser = subparsers.add_parser(
        'validate-index-issues',
        help='사이트별 Page indexing 이슈 현황 조회/Start New Validation 실행',
    )
    add_validate_all_arguments(validation_alias_parser)

    # validate-index-issues-all 명령어
    validation_all_frontend_parser = subparsers.add_parser(
        'validate-index-issues-all',
        help='저장된 GSC frontend session으로 사이트별 Page indexing 이슈 현황 조회/Start New Validation 실행',
    )
    add_validate_all_arguments(validation_all_frontend_parser)

    # validate-index-issues-all-browser 명령어
    validation_all_parser = subparsers.add_parser(
        'validate-index-issues-all-browser',
        help='관리 중인 GSC 사이트별 Page indexing 이슈 현황 조회/Start New Validation 실행',
    )
    validation_all_parser.add_argument('--submit', action='store_true', help='실제 START NEW VALIDATION 클릭')
    validation_all_parser.add_argument('--site', action='append', help='특정 사이트 URL만 처리 (여러 번 지정 가능)')
    validation_all_parser.add_argument(
        '--include-domain-properties',
        action='store_true',
        help='sc-domain 속성까지 포함 (기본: URL-prefix 속성만)',
    )
    validation_all_parser.add_argument('--only-status', default='actionable', help='처리할 Validation 상태 (기본: actionable = Failed + Not Started, all도 actionable과 동일)')
    validation_all_parser.add_argument('--include-started', action='store_true', help='Started 상태 이슈도 후보에 포함')
    validation_all_parser.add_argument('--limit-sites', type=int, help='처리할 최대 사이트 수')
    validation_all_parser.add_argument('--issue-limit', type=int, help='사이트별 처리할 최대 이슈 수')
    validation_all_parser.add_argument('--delay-ms', type=int, help='사이트 내부 이슈 사이 지연 시간(ms)')
    validation_all_parser.add_argument('--site-delay-ms', type=int, default=3000, help='사이트 사이 지연 시간(ms, 기본: 3000)')
    validation_all_parser.add_argument('--port', type=int, help='Chrome remote debugging 포트')
    validation_all_parser.add_argument('--retry-failed-sites', type=int, default=0, help='사이트 helper 실패 시 재시도 횟수')
    validation_all_parser.add_argument('--site-timeout-ms', type=int, default=180000, help='사이트별 helper 최대 실행 시간(ms, 기본: 180000)')
    validation_all_parser.add_argument('--batch-timeout-ms', type=int, default=900000, help='browser batch helper 최대 실행 시간(ms, 기본: 900000)')
    validation_all_parser.add_argument('--connect-timeout-ms', type=int, default=120000, help='Chrome DevTools 연결/승인 대기 시간(ms, 기본: 120000)')

    # inspect 명령어
    inspect_parser = subparsers.add_parser('inspect', help='URL 인덱싱 상태 검사')
    inspect_parser.add_argument('site_url', help='사이트 URL (예: https://example.com/)')
    inspect_parser.add_argument('page_url', help='검사할 페이지 URL')

    # query 명령어
    query_parser = subparsers.add_parser('query', help='검색 성능 데이터 조회')
    query_parser.add_argument('site_url', help='사이트 URL (예: https://example.com/)')
    query_parser.add_argument('--days', type=int, default=7, help='조회 기간 (일, 기본: 7)')
    query_parser.add_argument('--limit', type=int, default=100, help='최대 행 수 (기본: 100)')
    query_parser.add_argument('--by-date', action='store_true', help='날짜별 조회')
    query_parser.add_argument('--by-country', action='store_true', help='국가별 조회')
    query_parser.add_argument('--by-device', action='store_true', help='디바이스별 조회')
    query_parser.add_argument('--by-appearance', action='store_true', help='검색 형태별 조회')

    # pages 명령어
    pages_parser = subparsers.add_parser('pages', help='페이지별 검색 성능')
    pages_parser.add_argument('site_url', help='사이트 URL')
    pages_parser.add_argument('--days', type=int, default=7, help='조회 기간 (일)')
    pages_parser.add_argument('--limit', type=int, default=50, help='최대 행 수')

    args = parser.parse_args()

    if args.command == 'frontend-session':
        if args.frontend_session_command == 'export':
            helper = Path(__file__).with_name('gsc-frontend-indexing')
            cmd = [str(helper), '--export-session']
            if args.session_file:
                cmd.extend(['--session-file', args.session_file])
            if args.port is not None:
                cmd.extend(['--port', str(args.port)])
            sys.exit(subprocess.call(cmd))
        parser.error('frontend-session requires a subcommand')
    elif args.command == 'sites':
        list_sites()
    elif args.command == 'sitemaps':
        list_sitemaps(args.site_url)
    elif args.command == 'submit-sitemap':
        submit_sitemap(args.site_url, args.sitemap_url)
    elif args.command == 'refresh-sitemaps':
        refresh_sitemaps(args.site_urls or None, args.include_domain_properties)
    elif args.command == 'request-indexing-info':
        explain_request_indexing_api()
    elif args.command == 'request-indexing-browser':
        if not args.probe and not args.site_url:
            parser.error('request-indexing-browser requires site_url unless --probe is used')
        sys.exit(request_indexing_via_browser(args))
    elif args.command == 'validate-index-issues-browser':
        sys.exit(validate_index_issues_via_browser(args))
    elif args.command == 'validate-index-issues':
        sys.exit(validate_all_index_issues(args, browser=False))
    elif args.command == 'validate-index-issues-all':
        sys.exit(validate_all_index_issues(args, browser=False))
    elif args.command == 'validate-index-issues-all-browser':
        sys.exit(validate_all_index_issues(args, browser=True))
    elif args.command == 'inspect':
        inspect_url(args.site_url, args.page_url)
    elif args.command == 'pages':
        query_pages(args.site_url, args.days, args.limit)
    elif args.command == 'query':
        if args.by_date:
            dimensions = ['date']
        elif args.by_country:
            dimensions = ['country']
        elif args.by_device:
            dimensions = ['device']
        elif args.by_appearance:
            dimensions = ['searchAppearance']
        else:
            dimensions = ['query', 'page']
        query_search_analytics(args.site_url, args.days, dimensions, args.limit)
    else:
        parser.print_help()


if __name__ == '__main__':
    main()
