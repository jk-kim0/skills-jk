#!/usr/bin/env node
/*
 * Experimental Google Search Console frontend request-indexing helper.
 *
 * This intentionally runs the internal GSC fetches inside an already logged-in
 * Chrome Search Console tab via the Chrome DevTools Protocol. It does not copy
 * Google cookies to disk or print session tokens.
 */

const DEFAULT_PORT = 9222;
const RECAPTCHA_SITE_KEY = '6LeKMsIjAAAAAGP5PskdMId0tLXc7dL3LiO07Avf';

function usage() {
  console.log(`Usage:
  gsc-browser-indexing --site <site_url> --url <page_url> [--submit]
  gsc-browser-indexing --site <site_url> --file <urls.txt> [--submit] [--limit N]
  gsc-browser-indexing --site <site_url> --index-issues [--submit]
  gsc-browser-indexing --probe

Options:
  --site URL        GSC property URL, e.g. https://docs.querypie.com/ (repeatable for --index-issues)
  --url URL         Single URL to inspect/request
  --file PATH       Newline-delimited URL list
  --submit          Actually submit the selected action
                    For URL mode: submit Request indexing after live validation
                    For --index-issues: click VALIDATE FIX or START NEW VALIDATION per issue
  --index-issues    List or start validation for Page indexing issue rows
  --only-status S   Only process issue rows with this validation status (default: actionable = Failed + Not Started)
  --include-started Include rows already in Started validation state
  --limit N         Max URLs from --file or max issue rows from --index-issues
  --delay-ms N      Delay between URLs/issues (default: 15000)
  --site-delay-ms N Delay between repeated --site entries for --index-issues (default: 3000)
  --connect-timeout-ms N Chrome DevTools approval/connect timeout (default: 120000)
  --output-json     Print machine-readable JSON instead of the default table report for --index-issues
  --port N          Chrome remote debugging port (default: 9222)
  --target URL      Existing GSC tab URL hint (default: search-console)
  --probe           Verify a debuggable, logged-in GSC tab is reachable

Notes:
  - Chrome must be running with --remote-debugging-port=9222.
  - A Search Console tab must already be logged in.
  - This uses undocumented frontend RPCs and can break if Google changes GSC.
`);
}

function parseArgs(argv) {
  const args = { port: DEFAULT_PORT, delayMs: 15000, siteDelayMs: 3000, connectTimeoutMs: 120000, sites: [], submit: false, probe: false, target: 'search-console', indexIssues: false, onlyStatus: 'actionable', includeStarted: false, outputJson: false };
  for (let i = 2; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--help' || a === '-h') args.help = true;
    else if (a === '--submit') args.submit = true;
    else if (a === '--probe') args.probe = true;
    else if (a === '--index-issues') args.indexIssues = true;
    else if (a === '--include-started') args.includeStarted = true;
    else if (a === '--output-json') args.outputJson = true;
    else if (a === '--only-status') args.onlyStatus = argv[++i];
    else if (a === '--site') {
      const site = argv[++i];
      args.site = site;
      args.sites.push(site);
    }
    else if (a === '--url') args.url = argv[++i];
    else if (a === '--file') args.file = argv[++i];
    else if (a === '--limit') args.limit = Number(argv[++i]);
    else if (a === '--delay-ms') args.delayMs = Number(argv[++i]);
    else if (a === '--site-delay-ms') args.siteDelayMs = Number(argv[++i]);
    else if (a === '--connect-timeout-ms') args.connectTimeoutMs = Number(argv[++i]);
    else if (a === '--port') args.port = Number(argv[++i]);
    else if (a === '--target') args.target = argv[++i];
    else throw new Error(`Unknown argument: ${a}`);
  }
  return args;
}

async function readUrls(args) {
  if (args.url) return [args.url];
  if (!args.file) return [];
  const fs = await import('node:fs/promises');
  const content = await fs.readFile(args.file, 'utf8');
  let urls = content.split(/\r?\n/).map((line) => line.trim()).filter((line) => line && !line.startsWith('#'));
  if (Number.isFinite(args.limit)) urls = urls.slice(0, args.limit);
  return urls;
}

async function getBrowserWebSocketUrl(port) {
  try {
    const res = await fetch(`http://127.0.0.1:${port}/json/version`);
    if (res.ok) {
      const version = await res.json();
      if (version.webSocketDebuggerUrl) return version.webSocketDebuggerUrl;
    }
  } catch {
    // Fall through to DevToolsActivePort.
  }

  const fs = await import('node:fs/promises');
  const os = await import('node:os');
  const path = await import('node:path');
  const activePortPath = path.join(os.homedir(), 'Library/Application Support/Google/Chrome/DevToolsActivePort');
  const [activePort, browserPath] = (await fs.readFile(activePortPath, 'utf8')).trim().split(/\r?\n/);
  return `ws://127.0.0.1:${activePort || port}${browserPath}`;
}

function selectSearchConsoleTarget(targets, hint) {
  const infos = targets.targetInfos || targets;
  const isSearchConsolePage = (target) => {
    if (target.type !== 'page') return false;
    const url = String(target.url || '');
    const title = String(target.title || '');
    return url.includes('search.google.com/search-console')
      || (url.includes('accounts.google.com/') && title.includes('Google Search Console'));
  };
  const pages = infos.filter(isSearchConsolePage);
  const newestFirst = pages.slice().reverse();
  const page = newestFirst.find((t) => String(t.url || '').includes(hint))
    || newestFirst.find((t) => String(t.title || '').includes('Google Search Console'))
    || newestFirst[0];
  if (!page) {
    throw new Error('No open Search Console or Search Console login tab found in debuggable Chrome. Open https://search.google.com/search-console first.');
  }
  return page;
}

class CdpClient {
  constructor(wsUrl, connectTimeoutMs = 120000) {
    this.wsUrl = wsUrl;
    this.connectTimeoutMs = connectTimeoutMs;
    this.nextId = 1;
    this.pending = new Map();
  }

  async connect() {
    this.ws = new WebSocket(this.wsUrl);
    await new Promise((resolve, reject) => {
      const timer = setTimeout(() => reject(new Error('Timed out connecting to Chrome DevTools WebSocket; approve the Chrome remote-debugging prompt once, or relaunch Chrome with a persistent debugging profile.')), this.connectTimeoutMs);
      this.ws.addEventListener('open', () => { clearTimeout(timer); resolve(); }, { once: true });
      this.ws.addEventListener('error', (event) => { clearTimeout(timer); reject(new Error(`WebSocket error: ${event.message || 'unknown'}`)); }, { once: true });
    });
    this.ws.addEventListener('message', (event) => {
      let msg;
      try { msg = JSON.parse(event.data); } catch { return; }
      if (msg.id && this.pending.has(msg.id)) {
        const { resolve, reject } = this.pending.get(msg.id);
        this.pending.delete(msg.id);
        if (msg.error) reject(new Error(JSON.stringify(msg.error)));
        else resolve(msg.result);
      }
    });
  }

  send(method, params = {}, sessionId = undefined) {
    const id = this.nextId++;
    const message = { id, method, params };
    if (sessionId) message.sessionId = sessionId;
    const payload = JSON.stringify(message);
    return new Promise((resolve, reject) => {
      this.pending.set(id, { resolve, reject });
      this.ws.send(payload);
    });
  }

  async evaluate(fn, arg, sessionId = undefined) {
    const result = await this.send('Runtime.evaluate', {
      expression: `(${fn})(${JSON.stringify(arg)})`,
      awaitPromise: true,
      returnByValue: true,
      timeout: 180000,
    }, sessionId);
    if (result.exceptionDetails) throw new Error(result.exceptionDetails.text || JSON.stringify(result.exceptionDetails));
    return result.result ? result.result.value : undefined;
  }

  async clickPoint(x, y, sessionId = undefined) {
    await this.send('Input.dispatchMouseEvent', { type: 'mouseMoved', x, y, button: 'none' }, sessionId);
    await this.send('Input.dispatchMouseEvent', { type: 'mousePressed', x, y, button: 'left', buttons: 1, clickCount: 1 }, sessionId);
    await this.send('Input.dispatchMouseEvent', { type: 'mouseReleased', x, y, button: 'left', buttons: 0, clickCount: 1 }, sessionId);
  }

  close() {
    if (this.ws) this.ws.close();
  }
}

function pageFunction(input) {
  const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

  function parseRpcResponse(text, rpcid) {
    for (const rawLine of text.split('\n')) {
      const line = rawLine.trim();
      if (!line.startsWith('[[')) continue;
      let rows;
      try { rows = JSON.parse(line); } catch { continue; }
      for (const row of rows) {
        if (Array.isArray(row) && row[0] === 'wrb.fr' && row[1] === rpcid) {
          return row[2] ? JSON.parse(row[2]) : null;
        }
      }
    }
    throw new Error(`RPC ${rpcid} response was not found`);
  }

  function rpcUrl(rpcid) {
    const data = window.WIZ_global_data || {};
    const params = new URLSearchParams({
      rpcids: rpcid,
      'source-path': '/search-console/inspect',
      'f.sid': data.FdrFJe,
      bl: data.cfb2h,
      hl: 'en',
      'soc-app': '1',
      'soc-platform': '1',
      'soc-device': '1',
      _reqid: String(Math.floor(Math.random() * 900000) + 100000),
      rt: 'c',
    });
    return `/_/SearchConsoleAggReportUi/data/batchexecute?${params.toString()}`;
  }

  async function rpc(rpcid, args) {
    const data = window.WIZ_global_data || {};
    if (!data.SNlM0e || !data.FdrFJe || !data.cfb2h) {
      throw new Error('Missing GSC WIZ global tokens. Reload a logged-in Search Console tab and retry.');
    }
    const body = new URLSearchParams();
    body.set('f.req', JSON.stringify([[[rpcid, JSON.stringify(args), null, 'generic']]]));
    body.set('at', data.SNlM0e);
    const res = await fetch(rpcUrl(rpcid), {
      method: 'POST',
      credentials: 'include',
      headers: {
        'content-type': 'application/x-www-form-urlencoded;charset=UTF-8',
        'x-same-domain': '1',
      },
      body: body.toString() + '&',
    });
    const text = await res.text();
    if (!res.ok) throw new Error(`RPC ${rpcid} HTTP ${res.status}: ${text.slice(0, 300)}`);
    return parseRpcResponse(text, rpcid);
  }

  async function recaptchaToken() {
    if (!window.grecaptcha) {
      throw new Error('grecaptcha is not loaded in the current GSC tab. Open URL Inspection and click Request indexing once, or reload the page and retry.');
    }
    if (typeof window.grecaptcha.execute !== 'function') {
      throw new Error('grecaptcha.execute is unavailable in the current GSC tab.');
    }
    if (typeof window.grecaptcha.ready === 'function') {
      await new Promise((resolve) => window.grecaptcha.ready(resolve));
    }
    try {
      return await window.grecaptcha.execute(100000);
    } catch (firstError) {
      return await window.grecaptcha.execute(input.recaptchaSiteKey, { action: 'submit' });
    }
  }

  async function requestOne(siteUrl, pageUrl, submit) {
    const liveStart = await rpc('RVtklb', [pageUrl, null, 4, 1, siteUrl]);
    const liveJobId = liveStart && liveStart[0];
    if (!liveJobId) throw new Error(`Could not start live inspection for ${pageUrl}`);

    let poll = null;
    for (let attempt = 1; attempt <= input.pollAttempts; attempt++) {
      poll = await rpc('MrNfbc', [liveJobId, pageUrl]);
      if (poll && poll[1] === 2) break;
      await sleep(input.pollDelayMs);
    }
    if (!poll || poll[1] !== 2) {
      throw new Error(`Live inspection did not complete for ${pageUrl}`);
    }

    const validation = await rpc('HZPzjb', [liveJobId, pageUrl]);
    const canRequest = Array.isArray(validation) && Array.isArray(validation[0]) && validation[0][0] === 1;
    if (!canRequest) {
      return { url: pageUrl, liveJobId, submitted: false, canRequest: false, validation };
    }

    if (!submit) {
      return { url: pageUrl, liveJobId, submitted: false, canRequest: true, validation };
    }

    const token = await recaptchaToken();
    if (!token) throw new Error('Empty reCAPTCHA token');
    const submitResult = await rpc('Fj3Owf', [liveJobId, token, null, pageUrl]);
    return { url: pageUrl, liveJobId, submitted: true, canRequest: true, result: submitResult };
  }

  return requestOne(input.siteUrl, input.pageUrl, input.submit);
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function gscResourceId(siteUrl) {
  return encodeURIComponent(siteUrl);
}

function validationUrlFromDrilldownHref(drilldownHref) {
  const url = new URL(drilldownHref);
  url.pathname = '/search-console/index/validation';
  return url.toString();
}

async function waitForCondition(client, sessionId, fn, arg = {}, timeoutMs = 30000, intervalMs = 500) {
  const started = Date.now();
  let last;
  while (Date.now() - started < timeoutMs) {
    try {
      last = await client.evaluate(fn, arg, sessionId);
      if (last && last.ok) return last;
    } catch (error) {
      last = { ok: false, error: error.message };
    }
    await sleep(intervalMs);
  }
  throw new Error(`Timed out waiting for page condition: ${JSON.stringify(last)}`);
}

async function navigateAndWait(client, sessionId, url, timeoutMs = 45000) {
  await client.send('Page.navigate', { url }, sessionId);
  await waitForCondition(client, sessionId, () => ({
    ok: document.readyState === 'complete' || document.readyState === 'interactive',
    href: location.href,
    title: document.title,
  }), {}, timeoutMs);
  await sleep(1000);
}

function normalize(value) {
  return String(value || '')
    .replace(/<[^>]+>/g, ' ')
    .replace(/&#xE[0-9A-F]+;|&#\d+;/gi, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/\s+/g, ' ')
    .trim();
}

const ISSUE_COLUMNS = [
  ['SITE', 34],
  ['ROW', 7],
  ['VALIDATION', 13],
  ['PAGES', 7],
  ['OUTCOME', 15],
  ['ACTION', 12],
  ['REASON', 56],
];

function clipCell(value, width) {
  const text = normalize(value);
  if (text.length <= width) return text;
  if (width <= 1) return text.slice(0, width);
  return `${text.slice(0, width - 1)}…`;
}

function padCell(value, width) {
  return clipCell(value, width).padEnd(width, ' ');
}

function printIssueReportHeader({ mode, site, submit, discoveredCount, candidateCount }) {
  console.log(`GSC Page indexing issue report | mode=${mode} | site=${site} | submit=${submit}`);
  console.log(`discovered=${discoveredCount} candidates=${candidateCount}`);
  console.log(ISSUE_COLUMNS.map(([label, width]) => padCell(label, width)).join(' | '));
  console.log(ISSUE_COLUMNS.map(([, width]) => '-'.repeat(width)).join('-+-'));
}

function printIssueReportRow({ site, index, total, issue, outcome, action }) {
  const values = [
    site,
    `${index}/${total}`,
    issue.validation || '-',
    String(issue.pages || 0),
    outcome,
    action,
    issue.reason || '-',
  ];
  console.log(values.map((value, idx) => padCell(value, ISSUE_COLUMNS[idx][1])).join(' | '));
}

function printIssueReportSummary({ total, started = 0, skipped = 0, failed = 0 }) {
  console.log(`summary: total=${total} started=${started} skipped=${skipped} failed=${failed}`);
}

function isActionableValidationStatus(status) {
  const normalized = String(status || '').toLowerCase();
  return normalized === 'failed' || normalized === 'not started';
}

function scrapeIndexIssuesPage(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const rows = Array.from(document.querySelectorAll('tr[data-rowid]'));
  const issues = [];
  for (const row of rows) {
    const cells = Array.from(row.querySelectorAll('td'));
    if (cells.length < 5) continue;
    const reason = normalize(cells[0].innerText);
    const source = normalize(cells[1].innerText);
    const validation = normalize(cells[2].innerText.replace(/[\uE000-\uF8FF]/g, ''));
    const pagesText = normalize(cells[cells.length - 1].innerText).replace(/,/g, '');
    const pages = Number(pagesText);
    if (!reason) continue;
    issues.push({
      rowId: row.getAttribute('data-rowid'),
      reason,
      source,
      validation,
      pages: Number.isFinite(pages) ? pages : null,
    });
  }
  return {
    href: location.href,
    title: document.title,
    issues,
  };
}

function clickIssueRow(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const rows = Array.from(document.querySelectorAll('tr[data-rowid]'));
  const row = rows.find((candidate) => {
    const cells = Array.from(candidate.querySelectorAll('td'));
    return cells.length && normalize(cells[0].innerText) === input.reason;
  });
  if (!row) return { ok: false, reason: input.reason, message: 'issue row not found' };
  row.click();
  return { ok: true, reason: input.reason };
}


function getIssueRowRect(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const rows = Array.from(document.querySelectorAll('tr[data-rowid]'));
  const row = rows.find((candidate) => {
    const cells = Array.from(candidate.querySelectorAll('td'));
    return cells.length && normalize(cells[0].innerText) === input.reason;
  });
  if (!row) return { ok: false, reason: input.reason, message: 'issue row not found', href: location.href };
  row.scrollIntoView({ block: 'center', inline: 'center' });
  const rect = row.getBoundingClientRect();
  return {
    ok: true,
    reason: input.reason,
    href: location.href,
    x: rect.left + Math.min(rect.width - 8, Math.max(8, rect.width / 3)),
    y: rect.top + rect.height / 2,
    width: rect.width,
    height: rect.height,
  };
}

function readValidationPage(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const button = Array.from(document.querySelectorAll('button')).find((candidate) => normalize(candidate.innerText).toUpperCase() === 'START NEW VALIDATION');
  const heading = Array.from(document.querySelectorAll('h1')).map((h) => normalize(h.innerText)).find(Boolean) || '';
  const body = normalize(document.body.innerText);
  const statusMatch = body.match(/Validation\s+(started|failed|passed|not started)/i);
  return {
    href: location.href,
    heading,
    itemKey: new URL(location.href).searchParams.get('item_key'),
    hasStartButton: Boolean(button),
    validationStatus: statusMatch ? statusMatch[1] : null,
    buttonText: button ? normalize(button.innerText) : null,
  };
}

function readDrilldownValidationState(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const body = normalize(document.body.innerText || '');
  const statusMatch = body.match(/Validation\s+(started|failed|passed|not started)/i);
  const validateFixButton = Array.from(document.querySelectorAll('button, [role="button"]'))
    .find((candidate) => normalize(candidate.innerText || candidate.textContent).toUpperCase() === 'VALIDATE FIX');
  return {
    href: location.href,
    itemKey: new URL(location.href).searchParams.get('item_key'),
    hasValidateFixButton: Boolean(validateFixButton),
    validationStatus: statusMatch ? statusMatch[1] : null,
    bodyExcerpt: body.slice(0, 500),
  };
}

function getValidateFixButtonRect(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const button = Array.from(document.querySelectorAll('button, [role="button"]'))
    .find((candidate) => normalize(candidate.innerText || candidate.textContent).toUpperCase() === 'VALIDATE FIX');
  if (!button) return { ok: false, message: 'VALIDATE FIX button not found', href: location.href };
  button.scrollIntoView({ block: 'center', inline: 'center' });
  button.focus();
  const rect = button.getBoundingClientRect();
  return {
    ok: true,
    href: location.href,
    x: rect.left + rect.width / 2,
    y: rect.top + rect.height / 2,
    width: rect.width,
    height: rect.height,
  };
}

function clickValidateFixButton(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const button = Array.from(document.querySelectorAll('button, [role="button"]'))
    .find((candidate) => normalize(candidate.innerText || candidate.textContent).toUpperCase() === 'VALIDATE FIX');
  if (!button) return { ok: false, message: 'VALIDATE FIX button not found', href: location.href };
  button.scrollIntoView({ block: 'center', inline: 'center' });
  button.focus();
  button.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
  button.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));
  button.click();
  return { ok: true, href: location.href };
}

function clickSeeDetailsOnDrilldown(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const target = Array.from(document.querySelectorAll('a, button')).find((candidate) => {
    const text = normalize(candidate.innerText || candidate.textContent).toUpperCase();
    const href = candidate.getAttribute && candidate.getAttribute('href');
    return text === 'SEE DETAILS' || (href && href.includes('/search-console/index/validation'));
  });
  if (!target) return { ok: false, href: location.href };
  target.scrollIntoView({ block: 'center', inline: 'center' });
  target.click();
  return { ok: true, href: location.href };
}


function getSeeDetailsRect(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const desiredStatus = normalize(input && input.validationStatus).toLowerCase();
  const desiredReason = normalize(input && input.reason).toLowerCase();
  const candidates = Array.from(document.querySelectorAll('a, button'))
    .filter((candidate) => {
      const text = normalize(candidate.innerText || candidate.textContent).toUpperCase();
      const href = candidate.getAttribute && candidate.getAttribute('href');
      return text === 'SEE DETAILS' || (href && href.includes('/search-console/index/validation'));
    })
    .map((candidate) => {
      let container = candidate;
      let context = '';
      for (let depth = 0; container && depth < 6; depth += 1) {
        context = normalize(container.innerText || container.textContent);
        const lower = context.toLowerCase();
        if ((desiredStatus && lower.includes(desiredStatus)) || lower.includes('validation failed') || lower.includes('validation')) break;
        container = container.parentElement;
      }
      const lower = context.toLowerCase();
      let score = 0;
      if (desiredStatus && lower.includes(desiredStatus)) score += 10;
      if (lower.includes('validation failed')) score += 8;
      if (lower.includes('validation')) score += 4;
      if (desiredReason && lower.includes(desiredReason)) score += 2;
      return { candidate, score, context: context.slice(0, 300) };
    })
    .sort((a, b) => b.score - a.score);
  const selected = candidates[0];
  if (!selected) return { ok: false, href: location.href, message: 'SEE DETAILS button not found' };
  selected.candidate.scrollIntoView({ block: 'center', inline: 'center' });
  const rect = selected.candidate.getBoundingClientRect();
  return {
    ok: true,
    href: location.href,
    x: rect.left + rect.width / 2,
    y: rect.top + rect.height / 2,
    score: selected.score,
    context: selected.context,
  };
}

function getStartValidationButtonRect(input) {
  const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
  const button = Array.from(document.querySelectorAll('button')).find((candidate) => normalize(candidate.innerText).toUpperCase() === 'START NEW VALIDATION');
  if (!button) return { ok: false, message: 'START NEW VALIDATION button not found', href: location.href };
  button.scrollIntoView({ block: 'center', inline: 'center' });
  button.focus();
  const rect = button.getBoundingClientRect();
  return {
    ok: true,
    href: location.href,
    x: rect.left + rect.width / 2,
    y: rect.top + rect.height / 2,
    width: rect.width,
    height: rect.height,
  };
}

async function runIndexIssueValidations(client, sessionId, args) {
  if (!args.site) throw new Error('--site is required');
  const indexUrl = `https://search.google.com/search-console/index?resource_id=${gscResourceId(args.site)}`;
  await navigateAndWait(client, sessionId, indexUrl);
  await waitForCondition(client, sessionId, () => {
    const hasHeading = document.body.innerText.includes('Why pages aren') || document.body.innerText.includes('Page indexing');
    const hasRows = document.querySelectorAll('tr[data-rowid]').length > 0;
    return { ok: hasHeading && hasRows, href: location.href };
  });

  const scraped = await client.evaluate(scrapeIndexIssuesPage, {}, sessionId);
  const onlyStatus = args.onlyStatus ? args.onlyStatus.toLowerCase() : null;
  let candidates = scraped.issues.filter((issue) => {
    if (!issue.pages || issue.pages <= 0) return false;
    const validation = issue.validation.toLowerCase();
    if (!args.includeStarted && validation === 'started') return false;
    if (!onlyStatus) return isActionableValidationStatus(issue.validation);
    if (onlyStatus === 'actionable' || onlyStatus === 'all') return isActionableValidationStatus(issue.validation);
    return validation === onlyStatus;
  });
  if (Number.isFinite(args.limit)) candidates = candidates.slice(0, args.limit);

  if (args.outputJson) {
    console.log(JSON.stringify({ mode: 'index-issues', site: args.site, submit: args.submit, discovered: scraped.issues, candidates }, null, 2));
  } else {
    printIssueReportHeader({ mode: 'browser-cdp', site: args.site, submit: args.submit, discoveredCount: scraped.issues.length, candidateCount: candidates.length });
  }
  if (!args.submit) {
    if (!args.outputJson) {
      for (const [idx, issue] of candidates.entries()) {
        printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'DRY-RUN', action: 'candidate' });
      }
      printIssueReportSummary({ total: candidates.length });
    }
    return;
  }

  const results = [];
  for (const [idx, issue] of candidates.entries()) {
    const prefix = `[${idx + 1}/${candidates.length}] ${issue.reason}`;
    try {
      await navigateAndWait(client, sessionId, indexUrl);
      await waitForCondition(client, sessionId, () => ({ ok: document.querySelectorAll('tr[data-rowid]').length > 0, href: location.href }));
      const rowTarget = await client.evaluate(getIssueRowRect, { reason: issue.reason }, sessionId);
      if (!rowTarget.ok) throw new Error(rowTarget.message || 'could not locate issue row');
      await client.clickPoint(rowTarget.x, rowTarget.y, sessionId);
      await waitForCondition(client, sessionId, () => {
        const url = new URL(location.href);
        return { ok: url.pathname.includes('/index/drilldown') && Boolean(url.searchParams.get('item_key')), href: location.href, itemKey: url.searchParams.get('item_key') };
      });
      const drilldownHref = await client.evaluate(() => location.href, {}, sessionId);
      const itemKey = new URL(drilldownHref).searchParams.get('item_key');
      await waitForCondition(client, sessionId, () => {
        const body = document.body.innerText || '';
        const hasValidateFix = /VALIDATE\s+FIX/i.test(body);
        const hasSeeDetails = /SEE\s+DETAILS/i.test(body);
        const hasValidationCard = /Validation\s+(Failed|Not started|Started|Passed)/i.test(body);
        return { ok: hasValidateFix || hasSeeDetails || hasValidationCard, href: location.href, text: body.slice(0, 500) };
      }, {}, 45000, 1000);

      const drilldownBefore = await client.evaluate(readDrilldownValidationState, {}, sessionId);
      if (String(drilldownBefore.validationStatus || '').toLowerCase() === 'started') {
        const result = { ...issue, itemKey, submitted: true, before: drilldownBefore, after: drilldownBefore };
        if (args.outputJson) {
          console.log(`${prefix} OK already-started`);
          console.log(JSON.stringify(result));
        } else {
          printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'OK', action: 'already-started' });
        }
        results.push(result);
        continue;
      }
      if (String(drilldownBefore.validationStatus || '').toLowerCase() === 'passed') {
        const result = { ...issue, itemKey, submitted: false, skipped: true, before: drilldownBefore };
        if (args.outputJson) {
          console.log(`${prefix} SKIP passed`);
          console.log(JSON.stringify(result));
        } else {
          printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'SKIP', action: 'passed' });
        }
        results.push(result);
        continue;
      }
      if (drilldownBefore.hasValidateFixButton) {
        const clickTarget = await client.evaluate(getValidateFixButtonRect, {}, sessionId);
        if (!clickTarget.ok) throw new Error(clickTarget.message || 'could not locate VALIDATE FIX');
        await client.clickPoint(clickTarget.x, clickTarget.y, sessionId);
        const domClick = await client.evaluate(clickValidateFixButton, {}, sessionId);
        if (!domClick.ok) throw new Error(domClick.message || 'could not dispatch VALIDATE FIX click');
        await waitForCondition(client, sessionId, () => {
          const body = document.body.innerText || '';
          const hasValidateFix = /VALIDATE\s+FIX/i.test(body);
          return {
            ok: /Validation\s+(started|passed)/i.test(body) || !hasValidateFix,
            text: body.slice(0, 500),
            href: location.href,
            hasValidateFix,
          };
        }, {}, 180000, 1000);
        const drilldownAfter = await client.evaluate(readDrilldownValidationState, {}, sessionId);
        const submitted = String(drilldownAfter.validationStatus || '').toLowerCase() === 'started' || !drilldownAfter.hasValidateFixButton;
        const result = { ...issue, itemKey, submitted, before: drilldownBefore, after: drilldownAfter };
        if (args.outputJson) {
          console.log(`${prefix} OK ${submitted ? 'started' : 'clicked'}`);
          console.log(JSON.stringify(result));
        } else {
          printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'OK', action: submitted ? 'started' : 'clicked' });
        }
        results.push(result);
        continue;
      }

      const detailsTarget = await client.evaluate(getSeeDetailsRect, { reason: issue.reason, validationStatus: issue.validation }, sessionId);
      if (!detailsTarget.ok) {
        throw new Error(detailsTarget.message || 'could not locate validation SEE DETAILS or VALIDATE FIX on drilldown page');
      }
      await client.clickPoint(detailsTarget.x, detailsTarget.y, sessionId);
      await waitForCondition(client, sessionId, () => {
        const url = new URL(location.href);
        return { ok: url.pathname.includes('/index/validation') && Boolean(url.searchParams.get('item_key')), href: location.href };
      }, {}, 45000, 1000);
      await waitForCondition(client, sessionId, () => {
        const normalize = (value) => String(value || '').replace(/\s+/g, ' ').trim();
        const headings = Array.from(document.querySelectorAll('h1')).map((h) => normalize(h.innerText));
        const buttons = Array.from(document.querySelectorAll('button')).map((button) => normalize(button.innerText).toUpperCase());
        const body = document.body.innerText;
        const ready = headings.includes('Validation details') && (buttons.includes('START NEW VALIDATION') || /Validation\s+(started|passed|failed)/i.test(body));
        return { ok: ready, href: location.href, headings, hasStart: buttons.includes('START NEW VALIDATION') };
      }, {}, 120000, 1000);
      const before = await client.evaluate(readValidationPage, {}, sessionId);
      if (!before.hasStartButton) {
        const result = { ...issue, itemKey, submitted: false, skipped: true, before };
        if (args.outputJson) {
          console.log(`${prefix} SKIP ${before.validationStatus || 'no-start-button'}`);
          console.log(JSON.stringify(result));
        } else {
          printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'SKIP', action: before.validationStatus || 'no-start-button' });
        }
        results.push(result);
        continue;
      }
      const clickTarget = await client.evaluate(getStartValidationButtonRect, {}, sessionId);
      if (!clickTarget.ok) throw new Error(clickTarget.message || 'could not locate START NEW VALIDATION');
      await client.clickPoint(clickTarget.x, clickTarget.y, sessionId);
      await waitForCondition(client, sessionId, () => {
        const body = document.body.innerText;
        return { ok: /Validation\s+started/i.test(body) || !body.includes('Processing state update'), text: body.slice(0, 500), href: location.href };
      }, {}, 45000, 1000);
      const after = await client.evaluate(readValidationPage, {}, sessionId);
      const submitted = String(after.validationStatus || '').toLowerCase() === 'started' || !after.hasStartButton;
      const result = { ...issue, itemKey, submitted, before, after };
      if (args.outputJson) {
        console.log(`${prefix} OK ${submitted ? 'started' : 'clicked'}`);
        console.log(JSON.stringify(result));
      } else {
        printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'OK', action: submitted ? 'started' : 'clicked' });
      }
      results.push(result);
    } catch (error) {
      const result = { ...issue, submitted: false, error: error.message };
      if (args.outputJson) {
        console.log(`${prefix} FAIL ${error.message}`);
      } else {
        printIssueReportRow({ site: args.site, index: idx + 1, total: candidates.length, issue, outcome: 'FAIL', action: error.message });
      }
      results.push(result);
    }
    if (idx < candidates.length - 1) await sleep(args.delayMs);
  }
  const ok = results.filter((r) => r.submitted).length;
  const skipped = results.filter((r) => r.skipped).length;
  const failed = results.length - ok - skipped;
  if (args.outputJson) {
    console.log(JSON.stringify({ summary: { total: results.length, started: ok, skipped, failed }, results }, null, 2));
  } else {
    printIssueReportSummary({ total: results.length, started: ok, skipped, failed });
  }
  if (failed) process.exitCode = 1;
}

async function main() {
  const args = parseArgs(process.argv);
  if (args.help) { usage(); return; }

  const wsUrl = await getBrowserWebSocketUrl(args.port);
  const client = new CdpClient(wsUrl, args.connectTimeoutMs);
  await client.connect();
  let sessionId;
  let target;
  try {
    const targets = await client.send('Target.getTargets');
    target = selectSearchConsoleTarget(targets, args.target);
    await client.send('Target.activateTarget', { targetId: target.targetId });
    const attached = await client.send('Target.attachToTarget', { targetId: target.targetId, flatten: true });
    sessionId = attached.sessionId;
    if (!sessionId) throw new Error('Could not attach to Search Console target.');
    await client.send('Page.bringToFront', {}, sessionId).catch(() => undefined);

    if (args.probe) {
      const probe = await client.evaluate(() => ({
        href: location.href,
        title: document.title,
        hasGscTokens: Boolean(window.WIZ_global_data && WIZ_global_data.SNlM0e && WIZ_global_data.FdrFJe && WIZ_global_data.cfb2h),
        hasRecaptcha: typeof window.grecaptcha === 'object',
      }), {}, sessionId);
      console.log(JSON.stringify({ target: { id: target.targetId, url: target.url, title: target.title }, probe }, null, 2));
      return;
    }

    if (args.indexIssues) {
      const sites = args.sites && args.sites.length ? args.sites : (args.site ? [args.site] : []);
      if (!sites.length) throw new Error('--site is required');
      const batchResults = [];
      for (const [idx, site] of sites.entries()) {
        args.site = site;
        if (sites.length > 1) {
          console.log(`\n${'='.repeat(80)}\n[${idx + 1}/${sites.length}] ${site}\n${'='.repeat(80)}`);
        }
        const beforeExitCode = process.exitCode || 0;
        process.exitCode = 0;
        await runIndexIssueValidations(client, sessionId, args);
        const siteExitCode = process.exitCode || 0;
        batchResults.push({ siteUrl: site, returncode: siteExitCode });
        process.exitCode = beforeExitCode || siteExitCode;
        if (idx < sites.length - 1 && args.siteDelayMs) await sleep(args.siteDelayMs);
      }
      if (sites.length > 1) {
        const okCount = batchResults.filter((result) => result.returncode === 0).length;
        const failCount = batchResults.length - okCount;
        if (args.outputJson) {
          console.log(JSON.stringify({ summary: { sites: batchResults.length, ok: okCount, failed: failCount }, results: batchResults }, null, 2));
        } else {
          console.log(`site summary: total=${batchResults.length} ok=${okCount} failed=${failCount}`);
          console.log('SITE                               | RESULT');
          console.log('-----------------------------------+--------');
          for (const result of batchResults) {
            console.log(`${padCell(result.siteUrl, 34)} | ${result.returncode === 0 ? 'OK' : `FAIL(${result.returncode})`}`);
          }
        }
        if (failCount) process.exitCode = 1;
      }
      return;
    }

    if (!args.site) throw new Error('--site is required');
    const urls = await readUrls(args);
    if (!urls.length) throw new Error('--url or --file is required');

    for (const [idx, pageUrl] of urls.entries()) {
      const prefix = `[${idx + 1}/${urls.length}] ${pageUrl}`;
      try {
        const result = await client.evaluate(pageFunction, {
          siteUrl: args.site,
          pageUrl,
          submit: args.submit,
          pollAttempts: 30,
          pollDelayMs: 3000,
          recaptchaSiteKey: RECAPTCHA_SITE_KEY,
        }, sessionId);
        console.log(`${prefix} OK ${args.submit ? 'submitted' : 'validated'}`);
        console.log(JSON.stringify(result));
      } catch (error) {
        console.log(`${prefix} FAIL ${error.message}`);
      }
      if (idx < urls.length - 1) await new Promise((resolve) => setTimeout(resolve, args.delayMs));
    }
  } finally {
    client.close();
  }
}

main().catch((error) => {
  console.error(`ERROR: ${error.message}`);
  process.exit(1);
});
