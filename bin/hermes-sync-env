#!/usr/bin/env bash
# Materialize Hermes secrets from 1Password references into a local .env file.

[[ -n "${ZSH_VERSION:-}" ]] && emulate bash
set -o nounset -o errexit -o errtrace -o pipefail

SCRIPT_DIR=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
REPO_ROOT=$(dirname "$SCRIPT_DIR")

readonly BOLD_CYAN="\e[1;36m"
readonly BOLD_RED="\e[1;91m"
readonly RESET="\e[0m"

function log::info() {
  printf "%b# %s%b\n" "$BOLD_CYAN" "$*" "$RESET" 1>&2
}

function log::error() {
  printf "%bERROR: %s%b\n" "$BOLD_RED" "$*" "$RESET" 1>&2
}

function die() {
  log::error "$@"
  exit 1
}

function print_usage_and_exit() {
  local code=${1:-0} out=2
  [[ $code -eq 0 ]] && out=1
  cat >&"$out" <<END_OF_USAGE
Usage: bin/hermes-sync-env [source-env-file] [target-env-file]

Materializes secret references from a local .env.1password file into a local
Git-ignored .env file. This command may require 1Password authorization.

Defaults:
  source-env-file: .env.1password
  target-env-file: .env

END_OF_USAGE
  exit "$code"
}

function main() {
  local source_file=${1:-"$REPO_ROOT/.env.1password"}
  local target_file=${2:-"$REPO_ROOT/.env"}
  local tmp_file child_script

  case "${source_file}" in
    -h|--help) print_usage_and_exit 0 ;;
  esac

  command -v op >/dev/null 2>&1 || die "1Password CLI 'op' is not installed"
  [[ -f "$source_file" ]] || die "Source env file not found: $source_file"

  tmp_file=$(mktemp "${target_file}.XXXXXX")
  child_script=$(mktemp "${TMPDIR:-/tmp}/hermes-sync-env.XXXXXX")
  # shellcheck disable=SC2064
  trap "rm -f '$tmp_file' '$child_script'" EXIT

  log::info "Materializing $(basename "$target_file") from $(basename "$source_file")"
  umask 077

  cat > "$child_script" <<'END_OF_CHILD_SCRIPT'
#!/usr/bin/env bash
set -o nounset -o errexit -o pipefail

source_file=$1
target_file=$2

function dotenv_quote() {
  local value=$1 escaped
  if [[ "$value" =~ ^[A-Za-z0-9_./:@%+=,-]+$ ]]; then
    printf "%s" "$value"
  else
    escaped=${value//\'/\'\\\'\'}
    printf "'%s'" "$escaped"
  fi
}

: > "$target_file"
printf "# Generated by bin/hermes-sync-env. Do not commit.\\n" >> "$target_file"

while IFS= read -r line || [[ -n "$line" ]]; do
  line=${line%%#*}
  line=${line#"${line%%[![:space:]]*}"}
  line=${line%"${line##*[![:space:]]}"}
  [[ -z "$line" ]] && continue
  [[ "$line" == export\ * ]] && line=${line#export }
  [[ "$line" == *"="* ]] || continue

  key=${line%%=*}
  key=${key%"${key##*[![:space:]]}"}
  key=${key#"${key%%[![:space:]]*}"}
  [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || {
    printf "Invalid env key in %s: %s\\n" "$source_file" "$key" 1>&2
    exit 1
  }

  if [[ ! ${!key+x} ]]; then
    printf "Resolved value missing for key: %s\\n" "$key" 1>&2
    exit 1
  fi

  printf "%s=%s\\n" "$key" "$(dotenv_quote "${!key}")" >> "$target_file"
done < "$source_file"
END_OF_CHILD_SCRIPT
  chmod 700 "$child_script"

  op run --env-file "$source_file" -- "$child_script" "$source_file" "$tmp_file"

  mv "$tmp_file" "$target_file"
  chmod 600 "$target_file"
  trap - EXIT
  log::info "Wrote $target_file"
}

main "$@"
