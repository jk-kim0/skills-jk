#!/usr/bin/env python3.12
"""
Git Cleanup Branches

Scans git repositories under a workspace directory and identifies stale branches
that have been merged or closed via PR.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timedelta
from pathlib import Path
from urllib.parse import urlparse


@dataclass(frozen=True)
class BranchInfo:
    name: str
    last_commit: datetime | None


def run_command(cmd: list[str], cwd: str | None = None) -> tuple[int, str, str]:
    """Run a command and return (returncode, stdout, stderr)."""
    try:
        result = subprocess.run(
            cmd,
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=30,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except subprocess.TimeoutExpired:
        return 1, "", "Command timed out"
    except Exception as e:
        return 1, "", str(e)


def check_prerequisites() -> bool:
    """Check if required tools are installed."""
    code, _, _ = run_command(["gh", "--version"])
    if code != 0:
        print("Error: gh CLI is not installed.")
        print("Install it from: https://cli.github.com/")
        return False

    code, _, _ = run_command(["gh", "auth", "status"])
    if code != 0:
        print("Error: gh CLI is not authenticated.")
        print("Run: gh auth login")
        return False

    return True


def find_git_repos(workspace: Path) -> list[Path]:
    """Find all git repositories under the workspace directory."""
    repos = []

    if not workspace.exists():
        print(f"Error: Workspace directory does not exist: {workspace}")
        return repos

    for item in workspace.iterdir():
        if item.is_dir() and (item / ".git").exists():
            repos.append(item)

    return sorted(repos)


def get_base_branch(repo_path: Path) -> str:
    """Determine the base branch for a repository."""
    repo_name = repo_path.name
    if repo_name in ("querypie-mono", "deck"):
        return "develop"
    return "main"


def get_branch_infos(repo_path: Path) -> list[BranchInfo]:
    """Get local branch names and last commit dates in a single git call."""
    code, stdout, _ = run_command(
        [
            "git",
            "for-each-ref",
            "--format=%(refname:short)\t%(committerdate:unix)",
            "refs/heads",
        ],
        cwd=str(repo_path),
    )
    if code != 0 or not stdout:
        return []

    base_branch = get_base_branch(repo_path)
    exclude = {"main", "master", "develop", base_branch}
    branches: list[BranchInfo] = []

    for line in stdout.split("\n"):
        branch_name, _, ts = line.partition("\t")
        branch_name = branch_name.strip()
        if not branch_name or branch_name in exclude:
            continue

        last_commit = None
        ts = ts.strip()
        if ts:
            try:
                last_commit = datetime.fromtimestamp(int(ts))
            except (ValueError, OSError):
                last_commit = None

        branches.append(BranchInfo(name=branch_name, last_commit=last_commit))

    return branches


def parse_github_remote(repo_path: Path) -> tuple[str, str, str] | None:
    """Parse origin remote into (host, owner, repo)."""
    code, stdout, _ = run_command(
        ["git", "remote", "get-url", "origin"],
        cwd=str(repo_path),
    )
    if code != 0 or not stdout:
        return None

    remote_url = stdout.strip()

    if "://" in remote_url:
        parsed = urlparse(remote_url)
        host = parsed.hostname
        path = parsed.path.lstrip("/")
    elif ":" in remote_url and "@" in remote_url:
        host_part, _, path = remote_url.partition(":")
        _, _, host = host_part.partition("@")
    else:
        return None

    if not host:
        return None

    parts = path.removesuffix(".git").split("/")
    if len(parts) < 2:
        return None

    owner = parts[-2]
    repo = parts[-1]
    if not owner or not repo:
        return None

    return host, owner, repo


def get_pr_statuses(repo_path: Path, branches: list[str]) -> dict[str, str]:
    """Get PR status for branch heads in a repository using batched GraphQL."""
    if not branches:
        return {}

    remote = parse_github_remote(repo_path)
    if remote is None:
        return {}

    host, owner, repo = remote

    statuses: dict[str, str] = {}
    chunk_size = 20

    for chunk_start in range(0, len(branches), chunk_size):
        chunk = branches[chunk_start:chunk_start + chunk_size]
        fields = []
        alias_to_branch: dict[str, str] = {}
        for idx, branch in enumerate(chunk):
            alias = f"b{chunk_start + idx}"
            alias_to_branch[alias] = branch
            fields.append(
                f'{alias}: pullRequests(headRefName: {json.dumps(branch)}, '
                "states: [OPEN, MERGED, CLOSED], first: 1, "
                "orderBy: {field: UPDATED_AT, direction: DESC}) "
                "{ nodes { state } }"
            )

        query = (
            "query($owner:String!, $name:String!) { "
            "repository(owner:$owner, name:$name) { "
            f"{' '.join(fields)}"
            " } }"
        )

        cmd = ["gh", "api", "graphql"]
        if host != "github.com":
            cmd.extend(["--hostname", host])
        cmd.extend(
            [
                "-f",
                f"query={query}",
                "-F",
                f"owner={owner}",
                "-F",
                f"name={repo}",
            ]
        )

        code, stdout, _ = run_command(cmd, cwd=str(repo_path))
        if code != 0 or not stdout:
            continue

        try:
            payload = json.loads(stdout)
        except json.JSONDecodeError:
            continue

        repository = payload.get("data", {}).get("repository") or {}
        for alias, branch in alias_to_branch.items():
            nodes = repository.get(alias, {}).get("nodes") or []
            if not nodes:
                continue

            state = str(nodes[0].get("state", "")).upper()
            if state in ("OPEN", "MERGED", "CLOSED"):
                statuses[branch] = state

    return statuses


def get_remote_branches(repo_path: Path) -> set[str]:
    """Get remote branches under origin in a single git call."""
    code, stdout, _ = run_command(
        [
            "git",
            "for-each-ref",
            "--format=%(refname:short)",
            "refs/remotes/origin",
        ],
        cwd=str(repo_path),
    )
    if code != 0 or not stdout:
        return set()

    branches = set()
    for line in stdout.splitlines():
        ref = line.strip()
        if ref.startswith("origin/") and ref != "origin/HEAD":
            branches.add(ref.removeprefix("origin/"))
    return branches


def get_current_branch(repo_path: Path) -> str | None:
    """Get the currently checked out branch."""
    code, stdout, _ = run_command(
        ["git", "branch", "--show-current"],
        cwd=str(repo_path),
    )
    if code != 0 or not stdout:
        return None
    return stdout.strip()


def fetch_repo(repo_path: Path) -> bool:
    """Fetch and prune remote tracking branches."""
    code, _, stderr = run_command(
        ["git", "fetch", "--prune"],
        cwd=str(repo_path),
    )
    if code != 0:
        print(f"    ! fetch failed: {stderr}")
        return False
    return True


def delete_branch(repo_path: Path, branch: str) -> bool:
    """Delete a local branch, switching to base branch first if necessary."""
    current = get_current_branch(repo_path)
    if current == branch:
        base_branch = get_base_branch(repo_path)
        code, _, stderr = run_command(
            ["git", "checkout", base_branch],
            cwd=str(repo_path),
        )
        if code != 0:
            print(f"    ! checkout {base_branch} failed: {stderr}")
            return False

    code, _, stderr = run_command(
        ["git", "branch", "-D", branch],
        cwd=str(repo_path),
    )
    if code != 0:
        print(f"    ! delete failed: {stderr}")
        return False
    return True


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Scan workspace and cleanup stale branches in git repositories",
    )
    parser.add_argument(
        "dirs",
        nargs="*",
        help="Directory names under workspace to scan (default: all repos)",
    )
    parser.add_argument(
        "--workspace",
        type=Path,
        default=Path.home() / "workspace",
        help="Workspace directory to scan (default: ~/workspace)",
    )
    parser.add_argument(
        "--days",
        type=int,
        default=14,
        help="Only check branches with commits within this many days (default: 14)",
    )
    parser.add_argument(
        "--delete",
        action="store_true",
        help="Actually delete stale branches (default: dry-run)",
    )
    args = parser.parse_args()

    if not check_prerequisites():
        return 1

    workspace = args.workspace.expanduser().resolve()
    cutoff_date = datetime.now() - timedelta(days=args.days)

    print(f"Workspace: {workspace}")
    print(f"Checking branches with commits in the last {args.days} days")
    print(f"Mode: {'DELETE' if args.delete else 'dry-run'}")
    print()

    if args.dirs:
        repos = []
        for name in args.dirs:
            repo_path = workspace / name
            if not repo_path.is_dir():
                print(f"Warning: {repo_path} does not exist, skipping")
            elif not (repo_path / ".git").exists():
                print(f"Warning: {repo_path} is not a git repository, skipping")
            else:
                repos.append(repo_path)
        repos.sort()
    else:
        repos = find_git_repos(workspace)

    if not repos:
        print("No git repositories found.")
        return 0

    total_repos = len(repos)
    all_stale: list[tuple[Path, str]] = []

    for idx, repo_path in enumerate(repos, 1):
        repo_name = repo_path.name
        base_branch = get_base_branch(repo_path)

        print(f"[{idx}/{total_repos}] {repo_name} (base: {base_branch})")

        branch_infos = get_branch_infos(repo_path)
        if not branch_infos:
            print("  - no local branches to check")
            print()
            continue

        recent_branches = [
            branch_info
            for branch_info in branch_infos
            if branch_info.last_commit is not None and branch_info.last_commit >= cutoff_date
        ]
        old_or_unknown_count = len(branch_infos) - len(recent_branches)

        if not recent_branches:
            print(
                f"  - skipping fetch/API: {len(branch_infos)} branch(es), "
                "all older than cutoff or missing commit info"
            )
            print()
            continue

        print(
            f"  - checking {len(branch_infos)} branch(es) "
            f"({len(recent_branches)} recent, {old_or_unknown_count} skipped by date)..."
        )

        print("  - fetching...", end=" ", flush=True)
        if fetch_repo(repo_path):
            print("done")
        else:
            print()
            continue

        pr_statuses = get_pr_statuses(
            repo_path,
            [branch_info.name for branch_info in recent_branches],
        )
        remote_branches = get_remote_branches(repo_path)

        for branch_info in branch_infos:
            branch = branch_info.name
            # Print branch being checked
            print(f"    > {branch}: ", end="", flush=True)

            last_commit = branch_info.last_commit
            if last_commit is None:
                print("skip (no commit info)")
                continue

            commit_date_str = last_commit.strftime("%Y-%m-%d")

            if last_commit < cutoff_date:
                print(f"skip (old: {commit_date_str})")
                continue

            # Check PR status
            print("checking PR...", end=" ", flush=True)
            pr_status = pr_statuses.get(branch)
            remote_exists = branch in remote_branches

            # Build status parts
            pr_str = pr_status if pr_status else "none"
            remote_str = "remote" if remote_exists else "no-remote"

            # Determine and print result
            if pr_status in ("MERGED", "CLOSED"):
                all_stale.append((repo_path, branch))
                print(f"STALE [PR:{pr_str}, {commit_date_str}, {remote_str}]")
            elif pr_status == "OPEN":
                print(f"keep [PR:OPEN, {commit_date_str}, {remote_str}]")
            else:
                print(f"keep [no PR, {commit_date_str}, {remote_str}]")

        print()

    # Summary
    print("---")
    if not all_stale:
        print("Result: No stale branches found.")
        return 0

    repo_count = len(set(r for r, _ in all_stale))
    print(f"Result: {len(all_stale)} stale branch(es) in {repo_count} repo(s)")
    print()

    if not args.delete:
        print("Stale branches:")
        for repo_path, branch in all_stale:
            print(f"  - {repo_path.name}/{branch}")
        print()
        print("Run with --delete to remove these branches.")
        return 0

    # Delete branches
    print("Deleting stale branches...")

    deleted = 0
    for repo_path, branch in all_stale:
        print(f"  - {repo_path.name}/{branch}: ", end="", flush=True)
        if delete_branch(repo_path, branch):
            print("deleted")
            deleted += 1
        else:
            print("failed")

    print()
    print(f"Done: {deleted}/{len(all_stale)} deleted.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
