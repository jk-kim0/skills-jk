#!/usr/bin/env python3.12
"""
GSC 컨텐츠 분류별 검색 클릭수 집계 리포트

카테고리:
  Demo: Use Cases, AIP Features, ACP Features, Webinars
  Documentation: Introduction Decks, Glossary, Manuals, White Papers, Blogs

사용법:
    gsc-content-report <site_url> [--months 5] [--include-current]
"""

import argparse
import os
import pickle
import re
import sys
from datetime import datetime, timedelta
from pathlib import Path

try:
    from google.auth.transport.requests import Request
    from google.oauth2.credentials import Credentials
    from google_auth_oauthlib.flow import InstalledAppFlow
    from googleapiclient.discovery import build
except ImportError:
    print("필수 패키지가 설치되어 있지 않습니다.")
    print("  pip install google-auth google-auth-oauthlib google-api-python-client")
    sys.exit(1)

SCOPES = ['https://www.googleapis.com/auth/webmasters.readonly']
CLIENT_SECRET_FILE = os.environ.get(
    'GOOGLE_CLIENT_SECRET',
    os.path.expanduser('~/.config/google/client_secret.json'),
)
TOKEN_FILE = os.path.expanduser('~/.config/gsc/token.pickle')

CATEGORIES = {
    "Demo": [
        ("Use Cases",    r"/features/demo/use-cases/"),
        ("AIP Features", r"/features/demo/aip-features/"),
        ("ACP Features", r"/features/demo/acp-features/"),
        ("Webinars",     r"/features/demo/webinars/"),
    ],
    "Documentation": [
        ("Introduction Decks", r"/features/documentation/[^/]*-introduction-download"),
        ("Glossary",           r"/features/documentation/glossary-items"),
        ("Manuals",            r"/features/documentation/querypie-install-guide"),
        ("White Papers",       r"/features/documentation/white-paper/"),
        ("Blogs",              r"/features/documentation/blog/"),
    ],
}


def get_credentials():
    creds = None
    token_path = Path(TOKEN_FILE)
    if token_path.exists():
        with open(token_path, 'rb') as f:
            creds = pickle.load(f)
    if creds and creds.valid:
        return creds
    if creds and creds.expired and creds.refresh_token:
        creds.refresh(Request())
        with open(token_path, 'wb') as f:
            pickle.dump(creds, f)
        return creds
    if not os.path.exists(CLIENT_SECRET_FILE):
        print(f"오류: 클라이언트 시크릿 파일을 찾을 수 없습니다: {CLIENT_SECRET_FILE}")
        sys.exit(1)
    flow = InstalledAppFlow.from_client_secrets_file(CLIENT_SECRET_FILE, SCOPES)
    creds = flow.run_local_server(port=0)
    token_path.parent.mkdir(parents=True, exist_ok=True)
    with open(token_path, 'wb') as f:
        pickle.dump(creds, f)
    return creds


def fetch_pages(service, site_url, start_date, end_date):
    """주어진 기간의 모든 페이지별 클릭/노출 데이터를 가져옵니다."""
    all_rows = []
    start_row = 0
    limit = 25000

    while True:
        body = {
            'startDate': start_date,
            'endDate': end_date,
            'dimensions': ['page'],
            'rowLimit': limit,
            'startRow': start_row,
        }
        response = service.searchanalytics().query(
            siteUrl=site_url, body=body
        ).execute()
        rows = response.get('rows', [])
        all_rows.extend(rows)
        if len(rows) < limit:
            break
        start_row += limit

    return all_rows


def classify_pages(rows):
    """페이지 데이터를 카테고리별로 집계합니다."""
    locale_re = re.compile(r"/(ko|ja|en)/")

    results = {}
    for group, cats in CATEGORIES.items():
        results[group] = {label: {"clicks": 0, "impressions": 0} for label, _ in cats}

    for row in rows:
        url = row.get('keys', [''])[0]
        clicks = row.get('clicks', 0)
        impressions = row.get('impressions', 0)
        # URL에서 도메인 제거 후 locale prefix 제거
        path = re.sub(r'^https?://[^/]+', '', url)
        normalized = locale_re.sub('/', path)

        for group, cats in CATEGORIES.items():
            for label, pattern in cats:
                if re.search(pattern, normalized):
                    results[group][label]["clicks"] += clicks
                    results[group][label]["impressions"] += impressions
                    break

    return results


def get_month_ranges(months, include_current=False):
    today = datetime.now()
    ranges = []
    for i in range(months, 0, -1):
        d = today.replace(day=1)
        for _ in range(i):
            d = (d - timedelta(days=1)).replace(day=1)
        start = d
        if start.month == 12:
            end = start.replace(year=start.year + 1, month=1, day=1) - timedelta(days=1)
        else:
            end = start.replace(month=start.month + 1, day=1) - timedelta(days=1)
        label = start.strftime("%Y-%m")
        ranges.append((start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d"), label))

    if include_current:
        start = today.replace(day=1)
        end = today - timedelta(days=3)  # GSC 데이터는 최근 3일 불완전
        if end >= start:
            label = start.strftime("%Y-%m")
            ranges.append((start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d"), label))

    return ranges


def print_table(title, period, results):
    w = 80
    print(f"\n{'=' * w}")
    print(f"  {title}")
    print(f"  기간: {period}")
    print(f"{'=' * w}\n")

    print(f"  {'카테고리':<24} {'분류':<24} {'클릭':>8} {'노출':>10}")
    print(f"  {'-' * 74}")

    grand_clicks = 0
    grand_impressions = 0
    for group, cats in CATEGORIES.items():
        group_clicks = 0
        group_impressions = 0
        first = True
        for label, _ in cats:
            c = results[group][label]["clicks"]
            i = results[group][label]["impressions"]
            group_clicks += c
            group_impressions += i
            group_col = group if first else ""
            print(f"  {group_col:<24} {label:<24} {c:>8,} {i:>10,}")
            first = False
        print(f"  {'':<24} {'소계':<24} {group_clicks:>8,} {group_impressions:>10,}")
        print(f"  {'-' * 74}")
        grand_clicks += group_clicks
        grand_impressions += group_impressions

    print(f"  {'':<24} {'합계':<24} {grand_clicks:>8,} {grand_impressions:>10,}")


def main():
    parser = argparse.ArgumentParser(description='GSC 컨텐츠 분류별 클릭수 집계')
    parser.add_argument('site_url', help='사이트 URL (예: https://www.querypie.com/)')
    parser.add_argument('--months', type=int, default=5, help='조회 기간 (개월, 기본 5)')
    parser.add_argument('--include-current', action='store_true', help='현재 월 포함')
    args = parser.parse_args()

    creds = get_credentials()
    service = build('searchconsole', 'v1', credentials=creds)

    month_ranges = get_month_ranges(args.months, include_current=args.include_current)

    total_results = {}
    for group, cats in CATEGORIES.items():
        total_results[group] = {label: {"clicks": 0, "impressions": 0} for label, _ in cats}

    for start_date, end_date, label in month_ranges:
        print(f"\n  [{label}] 데이터 조회 중...", end="", flush=True)
        rows = fetch_pages(service, args.site_url, start_date, end_date)
        results = classify_pages(rows)
        print(f" {len(rows)}개 페이지 로드 완료")

        print_table(f"월간 컨텐츠별 검색 클릭수 — {label}", f"{start_date} ~ {end_date}", results)

        for group in results:
            for cat in results[group]:
                total_results[group][cat]["clicks"] += results[group][cat]["clicks"]
                total_results[group][cat]["impressions"] += results[group][cat]["impressions"]

    overall_start = month_ranges[0][0]
    overall_end = month_ranges[-1][1]
    print_table(
        f"전체 컨텐츠별 검색 클릭수 — 최근 {len(month_ranges)}개월 합산",
        f"{overall_start} ~ {overall_end}",
        total_results,
    )


if __name__ == '__main__':
    main()
